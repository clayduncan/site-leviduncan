---
import '../styles/global.css';
import { compliance } from '../data/compliance';
import { profileLinks, site } from '../data/site';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  robots?: string;
  schema?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description, canonical, robots, schema } = Astro.props;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).href;
const schemaItems = Array.isArray(schema) ? schema : schema ? [schema] : [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="msvalidate.01" content="1C808764522F73EA7E2768040CAA3069" />
    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-1BR97EBZEN"
    ></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'G-1BR97EBZEN');
    </script>
    <meta name="description" content={description} />
    {robots && <meta name="robots" content={robots} />}
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;550;650;750;800;850&family=Source+Serif+4:opsz,wght@8..60,600;8..60,700;8..60,800&display=swap"
    />
    <title>{title}</title>
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:image" content={new URL(site.heroImage, site.url).href} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(site.heroImage, site.url).href} />
    {
      schemaItems.map((schemaItem) => (
        <script type="application/ld+json" set:html={JSON.stringify(schemaItem)} />
      ))
    }
    <slot name="schema" />
  </head>
  <body>
    <header class="site-header" aria-label="Site header">
      <a class="site-logo" href="/" aria-label={`${site.name} home`}>
        <img src="/favicon.svg" width="40" height="40" alt="" aria-hidden="true" />
        <span>
          <strong>{site.name}</strong>
          <small>{site.tagline}</small>
        </span>
      </a>
      <div class="site-team-brand" aria-label="Duncan Mortgage Team powered by Princeton Mortgage">
        <strong>Duncan Mortgage Team</strong>
        <small>powered by Princeton Mortgage</small>
      </div>
      <nav class="site-nav" aria-label="Primary navigation">
        <a href="/huntsville/mortgage-guidance/">Mortgage Hub</a>
        <a href="/about/">About</a>
        <a href="/reviews/">Reviews</a>
        <a href="/events/">Events</a>
      </nav>
    </header>
    <main id="content">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="footer-contact">
        <p>
          {compliance.individualNmls.name}, {compliance.individualNmls.title},
          <a href={compliance.individualNmls.url} rel="noopener noreferrer" target="_blank">
            NMLS #{compliance.individualNmls.id}
          </a>
        </p>
        <p>
          <a href={site.phoneHref}>{site.phoneDisplay}</a> &middot;
          <a href={site.emailHref}>{site.email}</a>
        </p>
      </div>
      <div class="footer-links">
        <nav class="social-links" aria-label="Social profiles">
          {
            profileLinks.map((link) => (
              <a href={link.url} rel="me noopener noreferrer" target="_blank">
                {link.label}
              </a>
            ))
          }
        </nav>
        <p>&copy; {new Date().getFullYear()} {site.name}.</p>
      </div>
      <div class="site-disclosure">
        <p>
          {compliance.companyNmls.name},
          <a href={compliance.companyNmls.url} rel="noopener noreferrer" target="_blank">
            NMLS #{compliance.companyNmls.id}
          </a>.
        </p>
        <p>{compliance.equalHousing}</p>
      </div>
    </footer>
  </body>
</html>
