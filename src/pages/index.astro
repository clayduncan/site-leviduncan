---
import BaseLayout from '../layouts/BaseLayout.astro';
import { upcomingEvents } from '../data/events';
import { createEventJsonLd, createFaqJsonLd, homePageSchema } from '../data/schema';
import { site } from '../data/site';

const nextEvent = upcomingEvents[0];

const homepageFaqs = [
  {
    question: 'Who is Levi Duncan?',
    answer:
      'Levi Duncan is a Huntsville, Alabama Mortgage Loan Originator with Princeton Mortgage, focused on first-time homebuyer guidance, FHA loans, USDA loans, down payment assistance, and buyer readiness.',
  },
  {
    question: 'Who should start with Levi Duncan?',
    answer: `${site.serviceAreaStatement} Homebuyers should start with Levi when they want clear early mortgage guidance before applying or touring homes.`,
  },
];

const schema = [
  ...homePageSchema,
  createFaqJsonLd(homepageFaqs),
  ...(nextEvent ? [createEventJsonLd(nextEvent)] : []),
];
---

<BaseLayout
  title="Mortgage Guidance | Huntsville | Levi Duncan"
  description="Levi Duncan helps buyers compare first-time buyer, FHA, USDA, DPA, and investment property mortgage paths before the home search."
  schema={schema}
>
  <section class="hero-section landing-hero va-landing-hero" aria-labelledby="home-heading">
    <div class="hero-copy">
      <p class="eyebrow">Huntsville Mortgage Loan Originator</p>
      <h1 id="home-heading">A clearer first step for homebuyers in Huntsville.</h1>
      <p class="hero-lede">
        {site.serviceAreaStatement} He helps entry-level and mid-market buyers
        understand mortgage options, prepare early, and choose the right next
        step with Princeton Mortgage.
      </p>
      <div class="hero-actions" aria-label="Primary actions">
        <a class="button button-primary" href={site.calendlyUrl}>Book a call with Levi</a>
        <a class="button button-secondary" href={site.applicationUrl}>Apply with Levi</a>
      </div>
      <dl class="proof-strip" aria-label="Levi Duncan focus areas">
        <div>
          <dt>Focus</dt>
          <dd>First-time buyers, FHA, USDA, and DPA</dd>
        </div>
        <div>
          <dt>Education</dt>
          <dd>101 Homebuyer Review and Homebuyer Master Class</dd>
        </div>
        <div>
          <dt>Local</dt>
          <dd>Madison, Decatur, Athens, Albertville, and Arab</dd>
        </div>
      </dl>
    </div>
    <div class="hero-media va-hero-media">
      <img
        src={site.heroImage}
        width="800"
        height="800"
        alt="Levi Duncan, Huntsville Mortgage Loan Originator with Princeton Mortgage"
      />
      <div class="va-visual-card va-visual-card-top">
        <span>{site.tagline}</span>
        <strong>Buyer education, government-backed loans, and homebuyer readiness</strong>
      </div>
    </div>
  </section>

  <section class="section-band section-band-light" aria-labelledby="paths-heading">
    <div class="section-inner">
      <div class="section-heading section-heading-stacked">
        <p class="eyebrow">Start Here</p>
        <h2 id="paths-heading">Which Huntsville mortgage path fits your next step?</h2>
      </div>
      <div class="feature-grid">
        <article class="feature-card">
          <span>01</span>
          <h3>Homebuyers</h3>
          <p>
            Start with first-time buyer guidance, payment comfort, cash to
            close, credit preparation, and loan program fit before the home
            search gets urgent.
          </p>
          <a href="/huntsville/mortgage-guidance/first-time-home-buyer/">
            Explore first-time buyer guidance
          </a>
        </article>
        <article class="feature-card">
          <span>02</span>
          <h3>Real estate agents</h3>
          <p>
            Connect buyers with early mortgage education for FHA, USDA, down
            payment assistance, and first-time buyer questions.
          </p>
          <a href="/events/">View Homebuyer Master Class</a>
        </article>
        <article class="feature-card">
          <span>03</span>
          <h3>Homebuyer Master Class</h3>
          <p>
            The next listed event gives buyers a local education session before
            the pressure of an offer, inspection, insurance, title, and closing.
          </p>
          <a href="/events/">View upcoming events</a>
        </article>
      </div>
    </div>
  </section>

  <section class="section-band" aria-labelledby="first-time-home-heading">
    <div class="split-section">
      <div>
        <p class="eyebrow">First-Time Homebuyers</p>
        <h2 id="first-time-home-heading">Start with the questions that protect the first offer.</h2>
        <p>
          First-time buyers often ask the right questions too late. Levi's 101
          Homebuyer Review helps buyers compare payment comfort, cash to close,
          documents, loan options, and offer readiness before they fall in love
          with a house.
        </p>
        <div class="hero-actions" aria-label="First-time homebuyer homepage actions">
          <a class="button button-primary" href="/huntsville/mortgage-guidance/first-time-home-buyer/">
            First-time buyer guidance
          </a>
          <a class="button button-secondary" href={site.calendlyUrl}>Book Levi's 101 Review</a>
        </div>
      </div>
      <div class="local-context-panel" aria-label="First-time homebuyer review points">
        <article>
          <span>Payment</span>
          <strong>Comfort before qualification</strong>
          <p>
            Separate the amount a buyer may qualify for from the payment that
            still leaves room for life after closing.
          </p>
        </article>
        <article>
          <span>Cash</span>
          <strong>Plan beyond the down payment</strong>
          <p>
            Review closing costs, prepaid items, inspections, reserves, moving
            costs, and setup money before the offer stage.
          </p>
        </article>
        <article>
          <span>Offer</span>
          <strong>Know what can still change</strong>
          <p>
            Understand appraisal, insurance, title, credit, employment, and
            document conditions that can still matter after acceptance.
          </p>
        </article>
      </div>
    </div>
  </section>

  {
    nextEvent && (
      <section class="section-band section-band-light" aria-labelledby="event-heading">
        <div class="split-section split-section-contained">
          <div>
            <p class="eyebrow">Featured Event</p>
            <h2 id="event-heading">Next Homebuyer Master Class in Huntsville.</h2>
            <p>
              The Homebuyer Master Class is a monthly Huntsville-area education
              series for first-time and experienced buyers. The next session is at
              {` ${nextEvent.venue}`} and covers property strategy, title, legal,
              inspection, insurance, and financing strategy.
            </p>
            <div class="hero-actions">
              <a class="button button-primary" href="/events/">View events</a>
              <a class="button button-secondary" href={site.calendlyUrl}>Book Levi</a>
            </div>
          </div>
          <div class="local-context-panel" aria-label="Next Homebuyer Master Class details">
            <article>
              <span>{new Date(nextEvent.date).toLocaleDateString('en', {
                month: 'long',
                day: 'numeric',
                year: 'numeric',
              })}</span>
              <strong>{nextEvent.name}</strong>
              <p>{nextEvent.venue}, {nextEvent.city}, {nextEvent.state}</p>
            </article>
          </div>
        </div>
      </section>
    )
  }

  <section class="section-band" aria-labelledby="homepage-faq-heading">
    <div class="section-inner">
      <div class="section-heading">
        <p class="eyebrow">FAQ</p>
        <h2 id="homepage-faq-heading">Quick answers about Levi Duncan.</h2>
      </div>
      <div class="faq-list">
        {
          homepageFaqs.map((faq) => (
            <article>
              <h3>{faq.question}</h3>
              <p>{faq.answer}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
