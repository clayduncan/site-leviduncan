---
import BaseLayout from '../layouts/BaseLayout.astro';
import { reviews } from '../data/reviews';
import { createBreadcrumbJsonLd, personJsonLd } from '../data/schema';
import { site } from '../data/site';

const schema = [
  personJsonLd,
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    '@id': `${site.url}/reviews/#webpage`,
    url: `${site.url}/reviews/`,
    name: 'Levi Duncan Reviews',
    description:
      'Review page for Levi Duncan, Huntsville Mortgage Loan Originator with Princeton Mortgage.',
    mainEntity: reviews.map((review) => ({
      '@type': 'Review',
      author: review.author,
      reviewBody: review.text,
    })),
    isPartOf: { '@id': `${site.url}/#website` },
  },
  createBreadcrumbJsonLd([
    { name: 'Home', path: '/' },
    { name: 'Reviews', path: '/reviews/' },
  ]),
];
---

<BaseLayout
  title="Reviews | Huntsville | Levi Duncan"
  description="Reviews for Levi Duncan are coming soon while his Google Business Profile is being set up."
  schema={schema}
>
  <section class="hero-section landing-hero va-landing-hero" aria-labelledby="reviews-heading">
    <div class="hero-copy">
      <p class="eyebrow">Reviews</p>
      <h1 id="reviews-heading">Reviews</h1>
      <p class="hero-lede">
        Reviews are coming soon while Levi's Google Business Profile is in
        setup mode.
      </p>
      <p>
        Thank you so much to the real estate partners and current and past
        clients who have already been working with me. I appreciate the trust,
        and I look forward to proudly displaying your comments and reviews of
        my work once the profile is complete.
      </p>
      <div class="hero-actions">
        <a class="button button-primary" href={site.calendlyUrl}>Book a call with Levi</a>
        <a class="button button-secondary" href={site.applicationUrl}>Apply with Levi</a>
      </div>
    </div>
    <div class="hero-media va-hero-media">
      <img
        src={site.heroImage}
        width="800"
        height="800"
        alt="Levi Duncan, Huntsville Mortgage Loan Originator review page headshot"
      />
      <div class="va-visual-card va-visual-card-top">
        <span>{site.tagline}</span>
        <strong>Verified reviews coming after Google setup</strong>
      </div>
    </div>
  </section>

  <section class="section-band section-band-light" aria-labelledby="empty-heading">
    <div class="section-inner">
      <div class="answer-panel">
        <div>
          <p class="eyebrow">Current Status</p>
          <h2 id="empty-heading">Google Business Profile setup is next.</h2>
        </div>
        <p>
          Levi's Google Business Profile URL and verified reviews will be added
          as soon as the profile is complete.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
