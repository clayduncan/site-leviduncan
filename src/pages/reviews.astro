---
import BaseLayout from '../layouts/BaseLayout.astro';
import { reviewSources, reviewStats, reviews } from '../data/reviews';
import {
  createBreadcrumbJsonLd,
  createReviewJsonLd,
  personJsonLd,
} from '../data/schema';
import { site } from '../data/site';

const testimonialTree = reviewSources['testimonial-tree'];
const reviewSourceNames = [
  ...new Set(reviews.map((review) => review.sourceName)),
].join(' and ');
const reviewCountLabel =
  reviewStats.count === 1 ? '1 review' : `${reviewStats.count} reviews`;
const formattedReviews = reviews.map((review) => ({
  ...review,
  formattedDate: new Intl.DateTimeFormat('en-US', {
    month: 'long',
    day: 'numeric',
    year: 'numeric',
    timeZone: 'UTC',
  }).format(new Date(`${review.date}T00:00:00Z`)),
  stars: '★★★★★'.slice(0, review.rating),
}));

const schema = [
  personJsonLd,
  ...reviews.map((review) => createReviewJsonLd(review)),
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    '@id': `${site.url}/reviews/#webpage`,
    url: `${site.url}/reviews/`,
    name: 'Levi Duncan Reviews',
    description:
      'Reviews for Levi Duncan, Huntsville Mortgage Loan Originator with Princeton Mortgage.',
    mainEntity: reviews.map((review) => ({
      '@id': `${site.url}/reviews/#${review.id}`,
    })),
    isPartOf: { '@id': `${site.url}/#website` },
  },
  createBreadcrumbJsonLd([
    { name: 'Home', path: '/' },
    { name: 'Reviews', path: '/reviews/' },
  ]),
];
---

<BaseLayout
  title="Reviews | Huntsville | Levi Duncan"
  description={`Read verified ${reviewSourceNames} reviews for Levi Duncan, Huntsville Mortgage Loan Originator with Princeton Mortgage.`}
  schema={schema}
>
  <section class="hero-section landing-hero va-landing-hero reviews-hero" aria-labelledby="reviews-heading">
    <div class="hero-copy">
      <p class="eyebrow">Reviews</p>
      <h1 id="reviews-heading">Reviews</h1>
      <p class="hero-lede">
        Levi Duncan's reviews are currently pulled from {testimonialTree.name},
        where clients have rated him {reviewStats.averageRatingDisplay} out of
        5 across {reviewCountLabel}. Read the reviews below, visit the source
        profile, or leave a review through {testimonialTree.name}.
      </p>
      <div class="hero-actions" aria-label="Review source actions">
        <a class="button button-primary" href={testimonialTree.profileUrl}
          >Read all reviews</a
        >
        {
          testimonialTree.submissionUrl && (
            <a class="button button-secondary" href={testimonialTree.submissionUrl}>
              Leave a review
            </a>
          )
        }
      </div>
      <dl class="proof-strip" aria-label="Levi Duncan review themes">
        <div>
          <dt>Clarity</dt>
          <dd>Step-by-step guidance through the mortgage process</dd>
        </div>
        <div>
          <dt>Trust</dt>
          <dd>Clients willing to share their experience publicly</dd>
        </div>
        <div>
          <dt>Results</dt>
          <dd>Smoother homebuyer decisions from first call to closing</dd>
        </div>
      </dl>
    </div>
    <div class="hero-media va-hero-media">
      <img
        src={site.heroImage}
        width="800"
        height="800"
        alt="Levi Duncan, Huntsville Mortgage Loan Originator review page headshot"
      />
      <div class="rating-summary">
        <strong>{reviewStats.averageRatingDisplay}</strong>
        <span>{reviewStats.maxRating}-star average</span>
        <p>{reviewCountLabel} on {testimonialTree.name}</p>
      </div>
    </div>
  </section>

  <section class="section-band section-band-light" aria-labelledby="reviews-list-heading">
    <div class="section-inner">
      <div class="section-heading section-heading-wide">
        <div>
          <p class="eyebrow">Client Feedback</p>
          <h2 id="reviews-list-heading">What clients say about working with Levi.</h2>
        </div>
        <p>
          These reviews are rendered directly on Levi's site and attributed to
          their source platform. As Google reviews are added later, they can be
          added to the same reviews data layer without changing this page
          structure.
        </p>
      </div>
      <div class="reviews-grid">
        {
          formattedReviews.map((review) => (
            <article class="review-card" id={review.id}>
              <div class="review-card__header">
                <div>
                  <h3>{review.author}</h3>
                  <p>{review.formattedDate}</p>
                </div>
                <div>
                  <span>{review.sourceName}</span>
                  <div
                    class="review-stars"
                    aria-label={`${review.rating} out of ${reviewStats.maxRating} stars`}
                  >
                    {review.stars}
                  </div>
                </div>
              </div>
              <blockquote>{review.text}</blockquote>
            </article>
          ))
        }
      </div>
      <p class="reviews-note">
        Source: <a class="text-link" href={testimonialTree.profileUrl}
          >{testimonialTree.name}</a
        >. Visitors can also <a
          class="text-link"
          href={testimonialTree.submissionUrl}>leave Levi a review</a
        > through {testimonialTree.name}.
      </p>
    </div>
  </section>
</BaseLayout>
