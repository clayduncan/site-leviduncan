---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  createBreadcrumbJsonLd,
  organizationJsonLd,
  personJsonLd,
  professionalServiceJsonLd,
} from '../data/schema';
import { site } from '../data/site';

const pageUrl = new URL('/about/', site.url).href;

const schema = [
  personJsonLd,
  organizationJsonLd,
  professionalServiceJsonLd,
  {
    '@context': 'https://schema.org',
    '@type': 'ProfilePage',
    '@id': `${pageUrl}#webpage`,
    url: pageUrl,
    name: 'About Levi Duncan',
    description:
      'Profile page for Levi Duncan, Huntsville Mortgage Loan Originator with Princeton Mortgage.',
    mainEntity: { '@id': `${site.url}/#person` },
    isPartOf: { '@id': `${site.url}/#website` },
  },
  createBreadcrumbJsonLd([
    { name: 'Home', path: '/' },
    { name: 'About', path: '/about/' },
  ]),
];
---

<BaseLayout
  title="About Levi Duncan | Huntsville Mortgage"
  description="Learn about Levi Duncan, a Huntsville Mortgage Loan Originator focused on first-time buyers, FHA, USDA, DPA, and buyer readiness."
  schema={schema}
>
  <section class="hero-section landing-hero va-landing-hero" aria-labelledby="about-heading">
    <div class="hero-copy">
      <p class="eyebrow">About Levi Duncan</p>
      <h1 id="about-heading">Levi Duncan is a Huntsville Mortgage Loan Originator.</h1>
      <p class="hero-lede">
        Levi Duncan helps homebuyers in Huntsville, Madison, Decatur, Athens,
        Madison County, Morgan County, and the broader Tennessee Valley
        understand mortgage options early, including first-time buyer guidance,
        FHA loans, USDA loans, down payment assistance, and investment property
        financing.
      </p>
      <div class="hero-actions">
        <a class="button button-primary" href={site.calendlyUrl}>Book a call with Levi</a>
        <a class="button button-secondary" href={site.applicationUrl}>Apply with Levi</a>
      </div>
    </div>
    <div class="hero-media va-hero-media">
      <img
        src={site.heroImage}
        width="800"
        height="800"
        alt="Levi Duncan, Mortgage Loan Originator in Huntsville, Alabama"
      />
    </div>
  </section>

  <section class="section-band section-band-light" aria-labelledby="bio-heading">
    <div class="section-inner">
      <div class="answer-panel">
        <div>
          <p class="eyebrow">Bio</p>
          <h2 id="bio-heading">Who is Levi Duncan?</h2>
        </div>
        <p>
          Bio coming soon - full About content launches with the bio update.
          <!-- TODO: Replace placeholder bio when Levi's final bio paragraphs are approved. -->
        </p>
      </div>
      <div class="feature-grid">
        <article class="feature-card">
          <span>01</span>
          <h3>NMLS identity</h3>
          <p>Levi Duncan, Mortgage Loan Originator, NMLS {site.nmlsId}.</p>
        </article>
        <article class="feature-card">
          <span>02</span>
          <h3>Princeton Mortgage</h3>
          <p>Levi works with Princeton Mortgage, NMLS {site.company.nmlsId}.</p>
        </article>
        <article class="feature-card">
          <span>03</span>
          <h3>Five specializations</h3>
          <p>First-time buyers, FHA, USDA, down payment assistance, and investment property.</p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
