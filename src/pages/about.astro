---
import BaseLayout from '../layouts/BaseLayout.astro';
import { compliance } from '../data/compliance';
import {
  createBreadcrumbJsonLd,
  organizationJsonLd,
  personJsonLd,
  professionalServiceJsonLd,
} from '../data/schema';
import { site } from '../data/site';

const pageUrl = new URL('/about/', site.url).href;

const schema = [
  personJsonLd,
  organizationJsonLd,
  professionalServiceJsonLd,
  {
    '@context': 'https://schema.org',
    '@type': 'ProfilePage',
    '@id': `${pageUrl}#webpage`,
    url: pageUrl,
    name: 'About Levi Duncan',
    description:
      'Profile page for Levi Duncan, Huntsville Mortgage Loan Originator with Princeton Mortgage.',
    mainEntity: { '@id': `${site.url}/#person` },
    isPartOf: { '@id': `${site.url}/#website` },
  },
  createBreadcrumbJsonLd([
    { name: 'Home', path: '/' },
    { name: 'About', path: '/about/' },
  ]),
];
---

<BaseLayout
  title="About Levi Duncan | Huntsville Mortgage"
  description="Learn about Levi Duncan, a Huntsville Mortgage Loan Originator focused on first-time buyers, FHA, USDA, DPA, and buyer readiness."
  schema={schema}
>
  <section class="hero-section landing-hero va-landing-hero" aria-labelledby="about-heading">
    <div class="hero-copy">
      <p class="eyebrow">About Levi Duncan</p>
      <h1 id="about-heading">Levi Duncan is a Huntsville Mortgage Loan Originator.</h1>
      <p class="hero-lede">
        Levi Duncan is a Mortgage Loan Originator with Princeton Mortgage who
        works with buyers across Madison County, Marshall County, Morgan County,
        and the wider Tennessee Valley. His work starts with trust, clear
        education, and helping buyers understand what the next mortgage decision
        actually requires.
      </p>
      <div class="hero-actions">
        <a class="button button-primary" href={site.calendlyUrl}>Book a call with Levi</a>
        <a class="button button-secondary" href={site.applicationUrl}>Apply with Levi</a>
      </div>
    </div>
    <div class="hero-media va-hero-media">
      <img
        src={site.heroImage}
        width="800"
        height="800"
        alt="Levi Duncan, Mortgage Loan Originator in Huntsville, Alabama"
      />
      <div class="va-visual-card va-visual-card-top">
        <span>{site.tagline}</span>
        <strong>First-time buyers, FHA, USDA, and DPA guidance</strong>
      </div>
    </div>
  </section>

  <section class="section-band section-band-light" aria-labelledby="bio-heading">
    <div class="section-inner">
      <div class="section-heading section-heading-stacked">
        <p class="eyebrow">Bio</p>
        <h2 id="bio-heading">Who is Levi Duncan?</h2>
      </div>
      <div class="bio-copy bio-copy-wide">
        <p>
          Levi Duncan is a Christian, a Mortgage Loan Originator with Princeton
          Mortgage, and someone who believes trust is earned through honesty,
          integrity, and doing the right thing when no one is looking.
        </p>
        <p>
          In the mortgage business, Levi wants buyers to feel informed instead
          of overwhelmed. His goal is to help people compare practical mortgage
          options, pursue strong rates and great service, and understand the
          process early enough to make confident decisions. That is especially
          important for buyers who are preparing for their first purchase,
          comparing FHA or USDA financing, reviewing Alabama First Step down
          payment assistance, or trying to decide whether a home search is
          truly ready to begin.
        </p>
        <p>
          What Levi enjoys most is helping people get into a home they love and
          showing them that a mortgage process can be easier and smoother than
          they expected.
        </p>
        <p>
          Levi works with homebuyers across Madison, Decatur, Athens,
          Albertville, Arab, and the wider Tennessee Valley, serving Madison
          County, Marshall County, and Morgan County across North Alabama. His
          work is centered on early education, clear communication, and
          practical next steps before pressure builds around a contract,
          closing timeline, or changing market conditions.
        </p>
        <p>
          Through Princeton Mortgage, Levi helps buyers review the details that
          can shape a stronger purchase plan: payment comfort, cash to close,
          credit position, income documentation, loan program fit, property
          expectations, and timing. He also supports buyer education through
          the Homebuyer Master Class, a monthly Huntsville-area class built to
          help first-time and experienced buyers understand the full path before
          making a move.
        </p>
        <p>
          Levi believes good mortgage guidance should make the next decision
          easier to understand. Buyers should know what matters now, what can
          wait, what could create risk, and when it is time to move from
          conversation to application.
        </p>
        <p class="credential-link">
          NMLS #{site.nmlsId} —
          <a href={compliance.individualNmls.url}>View Levi's NMLS Consumer Access profile</a>
        </p>
      </div>
      <div class="feature-grid">
        <article class="feature-card">
          <span>01</span>
          <h3>Trust and integrity</h3>
          <p>Levi values honesty, follow-through, and doing the right thing when no one is looking.</p>
        </article>
        <article class="feature-card">
          <span>02</span>
          <h3>Clear service</h3>
          <p>He helps buyers understand the next step before the process feels pressured.</p>
        </article>
        <article class="feature-card">
          <span>03</span>
          <h3>Homebuyer focus</h3>
          <p>Levi focuses on first-time buyers, FHA, USDA, down payment assistance, and investment property.</p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
