---
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  createBreadcrumbJsonLd,
  createFaqJsonLd,
  organizationJsonLd,
  professionalServiceJsonLd,
  personJsonLd,
} from '../../data/schema';
import { site } from '../../data/site';

const pagePath = '/realtor-ai-training/';
const pageUrl = new URL(pagePath, site.url).href;

const faqs = [
  {
    question: 'What is AI training for REALTORS®?',
    answer:
      'AI training for REALTORS® helps real estate professionals use tools like generative AI for practical work such as content planning, listing presentation support, client education, follow-up workflows, research support, and better day-to-day organization.',
  },
  {
    question: 'Who is Clay Duncan’s AI training for?',
    answer:
      'Clay Duncan’s AI training is designed for REALTORS®, real estate teams, brokerage offices, loan officers, and mortgage professionals who want practical AI workflows instead of abstract technology hype.',
  },
  {
    question: 'Does AI replace the real estate professional?',
    answer:
      'No. Clay teaches AI as a support tool, not a replacement for professional judgment, relationship skills, local expertise, compliance awareness, or client-specific advice.',
  },
  {
    question: 'Can Clay teach an AI session for a real estate office or team?',
    answer:
      'Yes. Clay can teach practical AI sessions for offices, teams, and professional groups that want clear examples, useful workflows, and a responsible approach to AI adoption.',
  },
  {
    question: 'Is Princeton Mortgage building an AI training program around Clay’s classes?',
    answer:
      'Yes. Princeton Mortgage is launching an AI training division centered around Clay Duncan’s instruction, including a Skool learning community where Clay’s trainings can be featured as the program develops.',
  },
  {
    question: 'Why does AI training belong on a mortgage loan originator’s website?',
    answer:
      'Clay’s AI training supports his broader role as a mortgage educator and REALTOR® partner. It helps real estate professionals communicate more clearly, serve clients more efficiently, and understand where technology helps without replacing trusted human advice.',
  },
];

const industrySources = [
  {
    label: 'NAR artificial intelligence in real estate overview',
    url: 'https://www.nar.realtor/artificial-intelligence-real-estate',
  },
  {
    label: 'NAR: AI trust, accuracy, and client-facing use',
    url: 'https://www.nar.realtor/magazine/real-estate-news/technology/youve-tried-ai-but-can-you-trust-it',
  },
  {
    label: 'FTC advertising and marketing basics',
    url: 'https://www.ftc.gov/business-guidance/advertising-marketing',
  },
];

const schema = [
  personJsonLd,
  organizationJsonLd,
  professionalServiceJsonLd,
  createFaqJsonLd(faqs),
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': `${pageUrl}#webpage`,
    url: pageUrl,
    name: 'AI Training for REALTORS®',
    description:
      'Practical AI training from Clay Duncan for REALTORS®, real estate teams, and brokerage offices that want useful workflows, clearer client communication, and responsible AI adoption.',
    about: [
      { '@type': 'Thing', name: 'AI training for REALTORS®' },
      { '@type': 'Thing', name: 'real estate AI education' },
      { '@type': 'Thing', name: 'AI workflows for real estate professionals' },
      { '@type': 'Thing', name: 'Princeton Mortgage AI training' },
      { '@type': 'Thing', name: 'Skool learning community' },
      { '@type': 'Thing', name: 'responsible AI adoption' },
      { '@type': 'Place', name: 'Huntsville, Alabama' },
      { '@type': 'Place', name: 'North Alabama' },
    ],
    primaryImageOfPage: new URL('/images/clay-duncan-wbackground-1400.jpg', site.url).href,
    isPartOf: { '@id': `${site.url}/#website` },
    mainEntity: { '@id': `${site.url}/#person` },
    citation: industrySources.map((source) => source.url),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    '@id': `${pageUrl}#service`,
    name: 'AI Training for REALTORS®',
    description:
      'Practical AI education and workflow training for real estate professionals, teams, and offices.',
    provider: { '@id': `${site.url}/#person` },
    areaServed: site.serviceArea,
    audience: [
      { '@type': 'Audience', audienceType: 'REALTORS®' },
      { '@type': 'Audience', audienceType: 'real estate teams' },
      { '@type': 'Audience', audienceType: 'loan officers' },
    ],
  },
  createBreadcrumbJsonLd([
    { name: 'Home', path: '/' },
    { name: 'AI Training for REALTORS®', path: pagePath },
  ]),
];
---

<BaseLayout
  title="AI Training for REALTORS® | Clay Duncan"
  description="Practical AI training from Clay Duncan for REALTORS®, real estate teams, and brokerage offices that want useful workflows and clearer client communication."
  schema={schema}
>
  <section class="hero-section landing-hero va-landing-hero" aria-labelledby="ai-training-heading">
    <div class="hero-copy">
      <p class="eyebrow">REALTOR® AI Training</p>
      <h1 id="ai-training-heading">Practical AI training for real estate work that actually happens.</h1>
      <p class="hero-lede">
        Clay Duncan teaches REALTORS®, teams, and real estate offices how to use
        AI for clearer communication, better client education, sharper content,
        and more organized workflows without turning the work into tech theater.
      </p>
      <div class="hero-actions" aria-label="AI training actions">
        <a class="button button-primary" href={site.schedulingUrl}>Ask about a training session</a>
        <a class="button button-secondary" href="/reviews/">Read training reviews</a>
      </div>
      <dl class="proof-strip" aria-label="AI training highlights">
        <div>
          <dt>101</dt>
          <dd>Plain-language foundations for busy agents</dd>
        </div>
        <div>
          <dt>Systems</dt>
          <dd>Content, follow-up, presentations, and client education</dd>
        </div>
        <div>
          <dt>Princeton</dt>
          <dd>AI training division centered around Clay’s instruction</dd>
        </div>
      </dl>
    </div>
    <div class="hero-media va-hero-media">
      <img
        src="/images/clay-duncan-wbackground-1400.jpg"
        width="1400"
        height="787"
        alt="Clay Duncan teaching practical AI training for REALTORS and real estate professionals"
      />
      <div class="va-visual-card va-visual-card-top">
        <span>AI for real estate</span>
        <strong>Prompts, systems, client clarity, content, follow-up</strong>
      </div>
    </div>
  </section>

  <section class="section-band section-band-light" aria-labelledby="answer-heading">
    <div class="section-inner">
      <div class="answer-panel">
        <div>
          <p class="eyebrow">Direct Answer</p>
          <h2 id="answer-heading">What does Clay teach in AI training for REALTORS®?</h2>
        </div>
        <p>
          Clay teaches practical AI workflows for real estate professionals:
          content planning, listing presentation support, client education,
          follow-up ideas, prompt structure, better daily organization, and
          responsible use. The focus is useful work, not hype or replacement of
          professional judgment.
        </p>
      </div>
      <div class="feature-grid">
        <article class="feature-card">
          <span>01</span>
          <h3>Content and communication</h3>
          <p>
            Turn rough ideas into clearer social posts, email drafts, client
            education, market explanations, and listing-support materials with a
            stronger human review process.
          </p>
        </article>
        <article class="feature-card">
          <span>02</span>
          <h3>Client experience workflows</h3>
          <p>
            Use AI to organize buyer and seller questions, prepare better
            explanations, structure follow-up, and create more consistent
            touchpoints without sounding generic.
          </p>
        </article>
        <article class="feature-card">
          <span>03</span>
          <h3>Responsible adoption</h3>
          <p>
            Learn where AI helps, where it needs review, and why accuracy,
            privacy, fair housing awareness, advertising claims, and human
            expertise still matter.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="split-section" aria-labelledby="why-heading">
    <div>
      <p class="eyebrow">Why It Matters</p>
      <h2 id="why-heading">Agents do not need more noise. They need usable systems.</h2>
      <p>
        Real estate professionals are already hearing about AI from every
        direction. Clay’s training brings the conversation back to the work:
        serving clients, communicating clearly, staying organized, and knowing
        when a tool should support the professional instead of leading the
        conversation.
      </p>
      <div class="signal-list" aria-label="AI training use cases">
        <span>Listing presentations</span>
        <span>Client education</span>
        <span>Content planning</span>
        <span>Follow-up workflows</span>
      </div>
    </div>
    <div class="local-context-panel" aria-label="AI training audience paths">
      <article>
        <span>Individual agents</span>
        <strong>Better daily execution</strong>
        <p>Simple workflows for communication, content, planning, and client support.</p>
      </article>
      <article>
        <span>Teams and offices</span>
        <strong>Shared standards</strong>
        <p>Training that helps groups build common language around AI use and review.</p>
      </article>
      <article>
        <span>Referral partners</span>
        <strong>Stronger education</strong>
        <p>Mortgage and AI education can work together to create clearer client experiences.</p>
      </article>
    </div>
  </section>

  <section class="section-band section-band-light" aria-labelledby="platform-heading">
    <div class="section-inner">
      <div class="section-heading section-heading-row">
        <div>
          <p class="eyebrow">Princeton AI Training</p>
          <h2 id="platform-heading">A training platform is being built around Clay’s classes.</h2>
        </div>
        <p>
          Princeton Mortgage is launching an AI training division centered
          around Clay’s instruction, with a Skool learning community planned as
          the home for featured trainings, event updates, and reusable education.
        </p>
      </div>
      <div class="feature-grid">
        <article class="feature-card">
          <span>01</span>
          <h3>Featured classes</h3>
          <p>
            Clay’s AI 101, 102, and 103-style classes can become the core
            training library for agents, teams, and mortgage professionals who
            want practical instruction they can revisit.
          </p>
        </article>
        <article class="feature-card">
          <span>02</span>
          <h3>Upcoming sessions</h3>
          <p>
            As the program develops, this page can point visitors toward
            scheduled AI sessions, office trainings, Skool updates, and
            opportunities to learn directly from Clay.
          </p>
        </article>
        <article class="feature-card">
          <span>03</span>
          <h3>Past training recaps</h3>
          <p>
            Completed events, attendee feedback, and short recaps can show what
            Clay has already taught and give future attendees a clearer sense of
            the training experience.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section-band section-band-dark" aria-labelledby="training-path-heading">
    <div class="section-inner">
      <div class="section-heading">
        <p class="eyebrow">Training Path</p>
        <h2 id="training-path-heading">A practical way to move from curiosity to capability.</h2>
      </div>
      <div class="timeline-grid">
        <article>
          <span>Step 1</span>
          <h3>Understand the tools</h3>
          <p>
            Learn what AI can help with, what it cannot responsibly replace, and
            how to think clearly about prompts and outputs.
          </p>
        </article>
        <article>
          <span>Step 2</span>
          <h3>Build repeatable workflows</h3>
          <p>
            Create practical systems for content, client education, follow-up,
            meeting prep, and everyday real estate communication.
          </p>
        </article>
        <article>
          <span>Step 3</span>
          <h3>Review before publishing</h3>
          <p>
            Use AI as a draft partner while keeping accuracy, tone, compliance,
            privacy, and professional judgment in human hands.
          </p>
        </article>
        <article>
          <span>Step 4</span>
          <h3>Apply it to real work</h3>
          <p>
            Leave with examples and use cases that can be adapted to the
            agent’s market, voice, clients, and daily rhythm.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section-band va-topic-band" aria-labelledby="topics-heading">
    <div class="section-inner">
      <div class="section-heading section-heading-row">
        <div>
          <p class="eyebrow">Training Topics</p>
          <h2 id="topics-heading">The right AI class should feel like field training.</h2>
        </div>
        <p>
          Clay’s AI sessions are built around practical scenarios real estate
          professionals recognize, not abstract demonstrations that disappear
          when the class ends.
        </p>
      </div>
      <div class="topic-grid">
        <article>
          <h3>Prompt structure</h3>
          <p>
            Better inputs create more useful drafts, cleaner ideas, and less
            time spent fighting generic output.
          </p>
        </article>
        <article>
          <h3>Brand voice</h3>
          <p>
            AI should help agents sound more like themselves, not flatten every
            message into the same template.
          </p>
        </article>
        <article>
          <h3>Client education</h3>
          <p>
            Turn complicated real estate and mortgage topics into clearer
            explanations clients can understand.
          </p>
        </article>
        <article>
          <h3>Human review</h3>
          <p>
            Keep local expertise, relationship judgment, accuracy, and
            professional responsibility at the center.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section-band section-band-light" aria-labelledby="faq-heading">
    <div class="section-inner">
      <div class="section-heading section-heading-row">
        <div>
          <p class="eyebrow">AI Training FAQ</p>
          <h2 id="faq-heading">Questions agents and office leaders ask first.</h2>
        </div>
        <p>
          These answers help real estate professionals and office leaders
          understand Clay’s AI education role.
        </p>
      </div>
      <div class="faq-list">
        {
          faqs.map((faq) => (
            <article>
              <h3>{faq.question}</h3>
              <p>{faq.answer}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="split-section split-section-reverse" aria-labelledby="sources-heading">
    <div class="source-panel">
      <p class="eyebrow">Industry Sources</p>
      <ul>
        <li>
          This page uses NAR and FTC source material for AI adoption,
          professional-judgment, and advertising-claims context.
        </li>
        {
          industrySources.map((source) => (
            <li>
              <a href={source.url} rel="noopener noreferrer" target="_blank">
                {source.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
    <div>
      <p class="eyebrow">Next Step</p>
      <h2 id="sources-heading">Bring practical AI training to your office or team.</h2>
      <p>
        If your agents are curious about AI but need a clearer starting point,
        Clay can teach a practical session built around real estate workflows,
        mortgage-adjacent client education, and responsible use.
      </p>
      <div class="hero-actions" aria-label="AI training next steps">
        <a class="button button-primary" href={site.schedulingUrl}>Ask about training</a>
        <a class="button button-secondary" href="/events/">View events</a>
      </div>
    </div>
  </section>
</BaseLayout>
