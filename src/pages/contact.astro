---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  createBreadcrumbJsonLd,
  organizationJsonLd,
  professionalServiceJsonLd,
  personJsonLd,
} from '../data/schema';
import { site } from '../data/site';

const schema = [
  personJsonLd,
  organizationJsonLd,
  professionalServiceJsonLd,
  createBreadcrumbJsonLd([
    { name: 'Home', path: '/' },
    { name: 'Contact', path: '/contact/' },
  ]),
];
---

<BaseLayout
  title="Contact Clay Duncan | Huntsville Mortgage Guidance"
  description="Contact Clay Duncan for mortgage guidance, AI training, REALTOR® support, or a real conversation about your next step."
  schema={schema}
>
  <section class="hero-section hero-section-compact" aria-labelledby="contact-heading">
    <div class="hero-copy">
      <p class="eyebrow">Contact</p>
      <h1 id="contact-heading">Let’s have a real conversation.</h1>
      <p class="hero-lede">
        Reach out for mortgage guidance, AI training, REALTOR® support, or a
        conversation about your next professional chapter.
      </p>
    </div>
    <div class="contact-panel">
      <h2>Talk with Clay</h2>
      <p>
        <a href={site.phoneHref}>{site.phone}</a>
        <a href={site.emailHref}>{site.email}</a>
      </p>
      <a class="button button-primary" href={site.schedulingUrl}>
        Schedule a conversation
      </a>
    </div>
  </section>

  <section class="section-band section-band-light" aria-labelledby="contact-paths">
    <div class="section-inner">
      <div class="section-heading">
        <p class="eyebrow">Choose the next step</p>
        <h2 id="contact-paths">Different questions need different doors.</h2>
      </div>
      <div class="feature-grid">
        <article class="feature-card">
          <span>01</span>
          <h3>Mortgage</h3>
          <p>
            Start a purchase or refinance conversation and Clay can help you
            understand the right next step.
          </p>
          <a href={site.applicationUrl}>Start a loan application</a>
        </article>
        <article class="feature-card">
          <span>02</span>
          <h3>AI Training</h3>
          <p>
            Ask about AI sessions for REALTORS®, offices, teams, and real estate
            professionals who want practical workflows.
          </p>
          <a href="/events/">Explore training</a>
        </article>
        <article class="feature-card">
          <span>03</span>
          <h3>Loan Officer Growth</h3>
          <p>
            Have a confidential conversation about why to join, leadership fit,
            partner growth, and what a better mortgage career chapter could look
            like.
          </p>
          <a href="/join-us/">Explore why join</a>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
