---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';
---

<BaseLayout
  title="Page Not Found | Levi Duncan"
  description="The page you were looking for was not found. Start again with Levi Duncan's homepage or Huntsville mortgage guidance."
  robots="noindex, follow"
>
  <section class="hero-section hero-section-compact" aria-labelledby="not-found-heading">
    <div class="hero-copy">
      <p class="eyebrow">404</p>
      <h1 id="not-found-heading">This page is not available.</h1>
      <p class="hero-lede">
        The page may have moved during the Levi Duncan rebuild. Start with the
        homepage or the Huntsville mortgage guidance hub.
      </p>
      <div class="hero-actions">
        <a class="button button-primary" href="/">Go to homepage</a>
        <a class="button button-secondary" href="/huntsville/mortgage-guidance/"
          >Mortgage guidance</a
        >
        <a class="button button-secondary" href={site.calendlyUrl}>Book Levi</a>
      </div>
    </div>
  </section>
</BaseLayout>
