---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  createBreadcrumbJsonLd,
  organizationJsonLd,
  professionalServiceJsonLd,
  personJsonLd,
  websiteJsonLd,
} from '../data/schema';
import { site } from '../data/site';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);

const hasPosts = posts.length > 0;

const categoryLabels = {
  'ai-for-realtors': 'AI for REALTORS®',
  'events-recaps': 'Events & Recaps',
  'mortgage-strategy': 'Mortgage Strategy',
  'loan-officer-growth': 'Loan Officer Growth',
} as const;

const dateFormatter = new Intl.DateTimeFormat('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});

const getPostUrl = (id: string) =>
  `/blog/${id.replace(/\.mdx?$/, '').replace(/\/index$/, '')}/`;

const schema = [
  websiteJsonLd,
  personJsonLd,
  organizationJsonLd,
  professionalServiceJsonLd,
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    '@id': `${site.url}/blog/#webpage`,
    url: `${site.url}/blog/`,
    name: 'Clay Duncan Blog',
    description:
      'AI for REALTORS, event recaps, mortgage strategy, and loan officer growth insights from Clay Duncan.',
    isPartOf: { '@id': `${site.url}/#website` },
    mainEntity: {
      '@type': 'ItemList',
      itemListElement: posts.map((post, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        url: new URL(getPostUrl(post.id), site.url).href,
        name: post.data.title,
      })),
    },
    about: [
      { '@type': 'Thing', name: 'AI for REALTORS®' },
      { '@type': 'Thing', name: 'real estate AI education' },
      { '@type': 'Thing', name: 'Princeton Mortgage AI training' },
      { '@type': 'Thing', name: 'mortgage strategy' },
    ],
  },
  createBreadcrumbJsonLd([
    { name: 'Home', path: '/' },
    { name: 'Blog', path: '/blog/' },
  ]),
];
---

<BaseLayout
  title="AI for REALTORS® Blog | Clay Duncan"
  description="Practical AI education, event recaps, and professional guidance from Clay Duncan for REALTORS®, real estate teams, and mortgage professionals."
  robots={hasPosts ? undefined : 'noindex, follow'}
  schema={schema}
>
  <section class="hero-section landing-hero va-landing-hero" aria-labelledby="blog-heading">
    <div class="hero-copy">
      <p class="eyebrow">Blog</p>
      <h1 id="blog-heading">AI for REALTORS®, written for practical work.</h1>
      <p class="hero-lede">
        Clay’s writing focuses on practical AI education for REALTORS®, real
        estate teams, and mortgage professionals who want better systems,
        clearer client communication, and useful adoption without the hype.
      </p>
      <div class="hero-actions" aria-label="Blog actions">
        <a class="button button-primary" href="/realtor-ai-training/">Explore AI training</a>
        <a class="button button-secondary" href="/events/">View events</a>
      </div>
      <dl class="proof-strip" aria-label="Blog focus areas">
        <div>
          <dt>AI for REALTORS®</dt>
          <dd>Practical adoption, communication, and client education.</dd>
        </div>
        <div>
          <dt>Events & Recaps</dt>
          <dd>Training sessions, takeaways, and completed classes.</dd>
        </div>
        <div>
          <dt>Mortgage Strategy</dt>
          <dd>Selective guidance when it supports buyers and partners.</dd>
        </div>
      </dl>
    </div>
    <div class="hero-media va-hero-media">
      <img
        src="/images/clay-duncan-wbackground-1400.jpg"
        width="1400"
        height="787"
        alt="Clay Duncan writing and teaching practical AI education for REALTORS"
      />
      <div class="va-visual-card va-visual-card-top">
        <span>Writing Lane</span>
        <strong>AI education first. Mortgage commentary only when useful.</strong>
      </div>
    </div>
  </section>

  <section class="section-band section-band-light" aria-labelledby="articles-heading">
    <div class="section-inner">
      <div class="section-heading section-heading-wide">
        <div>
          <p class="eyebrow">Editorial Direction</p>
          <h2 id="articles-heading">Practical AI education, not hype.</h2>
          <p>
            The writing here is meant to help REALTORS®, real estate teams, and
            mortgage professionals think more clearly about AI, communication,
            client education, and useful adoption in real work.
          </p>
        </div>
      </div>
      <div class="blog-grid" aria-label="Latest blog articles">
        {
          posts.map((post) => (
            <article class="blog-card">
              <p>
                {categoryLabels[post.data.category]} ·{' '}
                {dateFormatter.format(post.data.publishDate)}
              </p>
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
              <a href={getPostUrl(post.id)}>Read article</a>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
