---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import {
  createBreadcrumbJsonLd,
  createFaqJsonLd,
  createMortgageServiceJsonLd,
  organizationJsonLd,
  professionalServiceJsonLd,
  personJsonLd,
} from '../../../data/schema';
import { site } from '../../../data/site';

const pagePath = '/huntsville/va-loans/';
const pageUrl = new URL(pagePath, site.url).href;

const faqs = [
  {
    question: 'Can I buy a home in Huntsville with a VA loan and no down payment?',
    answer:
      'Many VA-backed purchase loans allow eligible Veterans, service members, and survivors to buy with no down payment, as long as the borrower qualifies with the lender and the property appraises for the purchase price.',
  },
  {
    question: 'Do I need a Certificate of Eligibility for a VA loan?',
    answer:
      'Yes. Your Certificate of Eligibility, often called a COE, shows your lender that you qualify for the VA home loan benefit based on service history or duty status.',
  },
  {
    question: 'Who is eligible for a VA-backed home loan?',
    answer:
      'VA home loan eligibility is generally based on service history or duty status for Veterans, service members, National Guard members, Reserve members, and certain surviving spouses. The Certificate of Eligibility helps document that eligibility for the lender.',
  },
  {
    question: 'Does the VA set my mortgage interest rate?',
    answer:
      'No. The VA does not set most loan details. Your lender determines the interest rate, discount points, lender fees, and other loan costs.',
  },
  {
    question: 'Do VA loans have loan limits?',
    answer:
      'Borrowers with full VA entitlement generally do not have a VA loan limit. Borrowers with remaining entitlement may still be affected by county loan limits, and the lender must still approve the borrower for the requested loan amount.',
  },
  {
    question: 'What is the VA funding fee?',
    answer:
      'The VA funding fee is a one-time cost on many VA-backed loans. Some borrowers are exempt, including certain Veterans receiving VA compensation for a service-connected disability.',
  },
  {
    question: 'Is Redstone Arsenal relevant to VA loan planning in Huntsville?',
    answer:
      'Yes. Redstone Arsenal brings active-duty, Veteran, civilian, contractor, and relocation demand into the Huntsville housing market, so VA loan planning should account for commute, timing, eligibility, appraisal, and closing details.',
  },
];

const officialSources = [
  {
    label: 'VA-backed Veterans home loans',
    url: 'https://www.va.gov/housing-assistance/home-loans/',
  },
  {
    label: 'VA eligibility and Certificate of Eligibility',
    url: 'https://www.va.gov/housing-assistance/home-loans/eligibility/',
  },
  {
    label: 'VA entitlement and loan limits',
    url: 'https://www.va.gov/housing-assistance/home-loans/loan-limits/',
  },
  {
    label: 'VA funding fee and closing costs',
    url: 'https://www.va.gov/housing-assistance/home-loans/funding-fee-and-closing-costs/',
  },
  {
    label: 'Redstone Arsenal / Team Redstone',
    url: 'https://home.army.mil/redstone/',
  },
];

const schema = [
  personJsonLd,
  organizationJsonLd,
  professionalServiceJsonLd,
  createMortgageServiceJsonLd({
    pageUrl,
    name: 'VA Loan Guidance in Huntsville',
    description:
      'VA-backed home loan guidance for Huntsville, Redstone Arsenal, Madison, and North Alabama Veterans, service members, eligible surviving spouses, and military homebuyers.',
    serviceType: 'VA mortgage loan origination',
    audience: ['Veterans', 'service members', 'eligible surviving spouses', 'military homebuyers'],
  }),
  createFaqJsonLd(faqs),
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': `${pageUrl}#webpage`,
    url: pageUrl,
    name: 'VA Loans in Huntsville, Alabama',
    description:
      'VA-backed home loan guidance for Huntsville, Redstone Arsenal, Madison, and North Alabama military borrowers.',
    about: [
      { '@type': 'Thing', name: 'VA-backed home loans' },
      { '@type': 'Thing', name: 'VA eligibility and Certificate of Eligibility' },
      { '@type': 'Thing', name: 'VA entitlement and loan limits' },
      { '@type': 'Thing', name: 'VA funding fee and closing costs' },
      { '@type': 'Place', name: 'Redstone Arsenal' },
    ],
    primaryImageOfPage: new URL('/images/clay-duncan-wbackground-1400.jpg', site.url).href,
    isPartOf: { '@id': `${site.url}/#website` },
    mainEntity: { '@id': `${site.url}/#person` },
    citation: officialSources.map((source) => source.url),
  },
  createBreadcrumbJsonLd([
    { name: 'Home', path: '/' },
    { name: 'VA Loans in Huntsville', path: pagePath },
  ]),
];
---

<BaseLayout
  title="VA Loans in Huntsville, AL | Redstone Arsenal & North Alabama"
  description="VA loan guidance for Huntsville, Redstone Arsenal, Madison, and North Alabama Veterans, service members, eligible surviving spouses, and military homebuyers."
  schema={schema}
>
  <section class="hero-section landing-hero va-landing-hero" aria-labelledby="va-heading">
    <div class="hero-copy">
      <p class="eyebrow">Huntsville VA Loans</p>
      <h1 id="va-heading">VA loans in Huntsville for military homebuyers.</h1>
      <p class="hero-lede">
        Clay Duncan helps eligible Veterans, service members, surviving spouses,
        and Redstone Arsenal-area buyers understand VA-backed home loans with
        clear answers before they are under contract.
      </p>
      <div class="hero-actions" aria-label="VA loan actions">
        <a class="button button-primary" href={site.schedulingUrl}>Talk through VA options</a>
        <a class="button button-secondary" href={site.applicationUrl}>Start a loan application</a>
      </div>
      <dl class="proof-strip" aria-label="VA loan highlights">
        <div>
          <dt>$0</dt>
          <dd>Down payment may be available for eligible borrowers</dd>
        </div>
        <div>
          <dt>COE</dt>
          <dd>Certificate of Eligibility reviewed early</dd>
        </div>
        <div>
          <dt>RSA</dt>
          <dd>Local planning for Redstone Arsenal moves</dd>
        </div>
      </dl>
    </div>
    <div class="hero-media va-hero-media">
      <img
        src="/images/clay-duncan-wbackground-1400.jpg"
        width="1400"
        height="787"
        alt="Clay Duncan in a warm modern interior, Huntsville mortgage loan originator serving VA loan buyers"
      />
      <div class="va-visual-card va-visual-card-top">
        <span>VA-backed home loan</span>
        <strong>Eligibility, COE, entitlement, costs, closing</strong>
      </div>
    </div>
  </section>

  <section class="section-band section-band-light" aria-labelledby="answer-heading">
    <div class="section-inner">
      <div class="answer-panel">
        <div>
          <p class="eyebrow">Direct Answer</p>
          <h2 id="answer-heading">How do VA loans work in Huntsville?</h2>
        </div>
        <p>
          A VA-backed purchase loan is made by a private lender, while the U.S.
          Department of Veterans Affairs guarantees part of the loan. For
          eligible Huntsville, Madison, and Redstone Arsenal-area borrowers, that
          guaranty can help make homeownership possible with favorable terms,
          including no down payment in many qualified scenarios.
        </p>
      </div>
      <div class="feature-grid">
        <article class="feature-card">
          <span>01</span>
          <h3>VA eligibility and COE</h3>
          <p>
            A Certificate of Eligibility confirms that your service history or
            duty status supports the VA home loan benefit. You still need to
            meet lender requirements for credit, income, occupancy, and the
            property.
          </p>
        </article>
        <article class="feature-card">
          <span>02</span>
          <h3>Entitlement and loan limits</h3>
          <p>
            Full entitlement generally means no VA loan limit, as long as you
            qualify for the loan amount and the appraisal supports the value.
            Remaining entitlement can change the planning conversation.
          </p>
        </article>
        <article class="feature-card">
          <span>03</span>
          <h3>Funding fee and closing costs</h3>
          <p>
            VA purchase loans may include a one-time funding fee unless the
            borrower qualifies for an exemption, such as certain service-connected
            disability benefits. Closing-cost strategy matters before you write
            the offer.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="split-section" aria-labelledby="redstone-heading">
    <div>
      <p class="eyebrow">Local Context</p>
      <h2 id="redstone-heading">Why Redstone Arsenal changes the conversation.</h2>
      <p>
        Redstone Arsenal is a major federal center of excellence with military,
        civilian, contractor, and agency activity across North Alabama. For many
        VA-eligible buyers, the mortgage conversation is not just “Can I qualify?”
        It is also commute, timing, PCS or relocation pressure, appraisal
        strategy, and how quickly the lender can communicate with the buyer’s
        agent.
      </p>
      <div class="signal-list" aria-label="Local VA planning factors">
        <span>Huntsville</span>
        <span>Madison</span>
        <span>Redstone Arsenal</span>
        <span>North Alabama</span>
      </div>
    </div>
    <div class="local-context-panel" aria-label="Redstone Arsenal VA loan planning">
      <article>
        <span>Local signal</span>
        <strong>Redstone Arsenal</strong>
        <p>Military, federal, contractor, and relocation activity shapes buyer timing.</p>
      </article>
      <article>
        <span>Buyer path</span>
        <strong>VA purchase</strong>
        <p>Eligibility, entitlement, appraisal expectations, and closing costs get aligned early.</p>
      </article>
      <article>
        <span>Service area</span>
        <strong>North Alabama</strong>
        <p>Huntsville, Madison, Madison County, and surrounding communities.</p>
      </article>
    </div>
  </section>

  <section class="section-band section-band-dark" aria-labelledby="process-heading">
    <div class="section-inner">
      <div class="section-heading">
        <p class="eyebrow">Process</p>
        <h2 id="process-heading">A simple VA loan path.</h2>
      </div>
      <div class="timeline-grid">
        <article>
          <span>Step 1</span>
          <h3>Confirm eligibility</h3>
          <p>
            Review service history, duty status, and whether you have or need a
            Certificate of Eligibility before shopping seriously.
          </p>
        </article>
        <article>
          <span>Step 2</span>
          <h3>Map cash to close</h3>
          <p>
            Review income, debts, monthly comfort level, funding fee, seller
            credits, and closing-cost expectations.
          </p>
        </article>
        <article>
          <span>Step 3</span>
          <h3>Coordinate the offer</h3>
          <p>
            Align the pre-approval, real estate agent, VA appraisal expectations,
            and contract timeline.
          </p>
        </article>
        <article>
          <span>Step 4</span>
          <h3>Close with clarity</h3>
          <p>
            Keep communication steady through underwriting, conditions, closing
            disclosures, and the final signing.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section-band va-topic-band" aria-labelledby="topics-heading">
    <div class="section-inner">
      <div class="section-heading section-heading-row">
        <div>
          <p class="eyebrow">What Clay Helps Clarify</p>
          <h2 id="topics-heading">VA loan topics that should be clear before you make an offer.</h2>
        </div>
        <p>
          The goal is not just pre-approval. The goal is a purchase plan your
          real estate agent, lender, and closing team can execute without
          avoidable surprises.
        </p>
      </div>
      <div class="topic-grid">
        <article>
          <h3>First use vs. subsequent use</h3>
          <p>
            Prior VA loan use can affect entitlement, funding fee planning, and
            how much room you have in the next purchase.
          </p>
        </article>
        <article>
          <h3>Primary residence requirement</h3>
          <p>
            VA purchase loans are designed for eligible borrowers buying a home
            they intend to occupy, not a pure investment property.
          </p>
        </article>
        <article>
          <h3>Appraisal and property condition</h3>
          <p>
            VA appraisal expectations can shape contract strategy, repairs, and
            timing, especially in competitive local markets.
          </p>
        </article>
        <article>
          <h3>Seller credits and concessions</h3>
          <p>
            Closing-cost conversations should happen before the offer so cash to
            close, credits, and contract terms work together.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section-band section-band-light" aria-labelledby="faq-heading">
    <div class="section-inner">
      <div class="section-heading section-heading-row">
        <div>
          <p class="eyebrow">VA Loan FAQ</p>
          <h2 id="faq-heading">Questions Huntsville VA buyers ask first.</h2>
        </div>
        <p>
          These answers are intentionally direct so homebuyers and AI answer
          engines can understand the basics quickly.
        </p>
      </div>
      <div class="faq-list">
        {
          faqs.map((faq) => (
            <article>
              <h3>{faq.question}</h3>
              <p>{faq.answer}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="split-section split-section-reverse" aria-labelledby="sources-heading">
    <div class="source-panel">
      <p class="eyebrow">Official Sources</p>
      <ul>
        <li>
          This page links to official VA and U.S. Army sources for borrower
          education and local Redstone Arsenal context.
        </li>
        {
          officialSources.map((source) => (
            <li>
              <a href={source.url} rel="noopener noreferrer" target="_blank">
                {source.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
    <div>
      <p class="eyebrow">Next Step</p>
      <h2 id="sources-heading">Talk through your VA loan scenario.</h2>
      <p>
        Every VA buyer’s situation is a little different: first use or subsequent
        use, available entitlement, disability exemption, timing, property type,
        and cash-to-close comfort level.
      </p>
      <div class="hero-actions" aria-label="VA loan next steps">
        <a class="button button-primary" href={site.schedulingUrl}>Chat with Clay</a>
        <a class="button button-secondary" href={site.applicationUrl}>Start application</a>
      </div>
    </div>
  </section>
</BaseLayout>
