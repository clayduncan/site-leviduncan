---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import {
  createBreadcrumbJsonLd,
  createFaqJsonLd,
  createMortgageServiceJsonLd,
  organizationJsonLd,
  professionalServiceJsonLd,
  personJsonLd,
} from '../../../data/schema';
import { site } from '../../../data/site';

const pagePath = '/huntsville/complex-mortgage-guidance/';
const pageUrl = new URL(pagePath, site.url).href;

const faqs = [
  {
    question: 'What is a complex mortgage situation?',
    answer:
      'A complex mortgage situation is a home loan scenario where the buyer needs more strategy than a basic rate quote. It may involve self-employment, variable income, relocation timing, multiple properties, large assets, jumbo financing, VA eligibility, appraisal risk, or a tight contract timeline.',
  },
  {
    question: 'When should I talk to a mortgage loan originator about a complex file?',
    answer:
      'Talk to a mortgage loan originator before you write an offer or make a major financial move. Complex files benefit from early planning because income, assets, documentation, property details, and contract terms can all affect the best path.',
  },
  {
    question: 'Can complex mortgage guidance help REALTORS®?',
    answer:
      'Yes. REALTORS® often need a lender who can explain the financing risk, timeline, documentation needs, and offer strategy in plain language before a buyer enters a competitive negotiation.',
  },
  {
    question: 'Is jumbo financing always considered complex?',
    answer:
      'Not always, but jumbo loans often require more detailed review of reserves, income, assets, property type, appraisal expectations, and closing timeline. That makes early strategy especially important for higher-priced purchases.',
  },
  {
    question: 'Does complex mortgage guidance replace a loan application?',
    answer:
      'No. Guidance helps identify the right questions, documents, and strategy. A formal loan application and underwriting review are still needed before any approval or loan terms can be confirmed.',
  },
];

const officialSources = [
  {
    label: 'CFPB home loan toolkit',
    url: 'https://www.consumerfinance.gov/owning-a-home/explore/home-loan-toolkit/',
  },
  {
    label: 'CFPB Loan Estimate and Closing Disclosure overview',
    url: 'https://www.consumerfinance.gov/about-us/blog/loan-estimate-and-closing-disclosure-choose-right-home-loans/',
  },
  {
    label: 'CFPB closing documents guidance',
    url: 'https://www.consumerfinance.gov/ask-cfpb/what-documents-should-i-receive-before-closing-on-a-mortgage-loan-en-181/',
  },
];

const schema = [
  personJsonLd,
  organizationJsonLd,
  professionalServiceJsonLd,
  createMortgageServiceJsonLd({
    pageUrl,
    name: 'Complex Mortgage Guidance in Huntsville',
    description:
      'Complex mortgage guidance for self-employment, variable income, relocation timing, multiple properties, large assets, VA eligibility, jumbo financing, and offer planning.',
    serviceType: 'Complex mortgage loan origination guidance',
    audience: ['self-employed buyers', 'relocating buyers', 'jumbo buyers', 'buyers with complex mortgage questions'],
  }),
  createFaqJsonLd(faqs),
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': `${pageUrl}#webpage`,
    url: pageUrl,
    name: 'Complex Mortgage Guidance in Huntsville, Alabama',
    description:
      'Mortgage strategy for Huntsville and North Alabama buyers with complex income, assets, timing, jumbo financing, VA eligibility, or offer-readiness questions.',
    about: [
      { '@type': 'Thing', name: 'complex mortgage guidance' },
      { '@type': 'Thing', name: 'mortgage strategy' },
      { '@type': 'Thing', name: 'self-employed mortgage documentation' },
      { '@type': 'Thing', name: 'offer readiness' },
      { '@type': 'Place', name: 'Huntsville, Alabama' },
      { '@type': 'Place', name: 'Madison, Alabama' },
      { '@type': 'Place', name: 'North Alabama' },
    ],
    primaryImageOfPage: new URL('/images/clay-duncan-wbackground-1400.jpg', site.url).href,
    isPartOf: { '@id': `${site.url}/#website` },
    mainEntity: { '@id': `${site.url}/#person` },
    citation: officialSources.map((source) => source.url),
  },
  createBreadcrumbJsonLd([
    { name: 'Home', path: '/' },
    { name: 'Complex Mortgage Guidance in Huntsville', path: pagePath },
  ]),
];
---

<BaseLayout
  title="Complex Mortgage Guidance in Huntsville, AL | Clay Duncan"
  description="Mortgage strategy for Huntsville and North Alabama buyers with complex income, assets, timing, jumbo financing, VA eligibility, or offer-readiness questions."
  schema={schema}
>
  <section class="hero-section landing-hero va-landing-hero" aria-labelledby="complex-heading">
    <div class="hero-copy">
      <p class="eyebrow">Complex Mortgage Guidance</p>
      <h1 id="complex-heading">A clearer mortgage plan when the file is not simple.</h1>
      <p class="hero-lede">
        Clay Duncan helps Huntsville, Madison, and North Alabama buyers think
        through income, assets, timing, property details, VA or jumbo questions,
        and offer strategy before a complicated loan scenario becomes a closing
        problem.
      </p>
      <div class="hero-actions" aria-label="Complex mortgage guidance actions">
        <a class="button button-primary" href={site.schedulingUrl}>Talk through your scenario</a>
        <a class="button button-secondary" href={site.applicationUrl}>Start a loan application</a>
      </div>
      <dl class="proof-strip" aria-label="Complex mortgage guidance highlights">
        <div>
          <dt>Strategy</dt>
          <dd>Clarify the path before the offer</dd>
        </div>
        <div>
          <dt>Details</dt>
          <dd>Income, assets, timing, and documentation</dd>
        </div>
        <div>
          <dt>Local</dt>
          <dd>Huntsville, Madison, and North Alabama guidance</dd>
        </div>
      </dl>
    </div>
    <div class="hero-media va-hero-media">
      <img
        src="/images/clay-duncan-wbackground-1400.jpg"
        width="1400"
        height="787"
        alt="Clay Duncan in a warm modern interior, Huntsville mortgage loan originator for complex mortgage guidance"
      />
      <div class="va-visual-card va-visual-card-top">
        <span>Complex buyer strategy</span>
        <strong>Income, assets, timing, property, offer, closing</strong>
      </div>
    </div>
  </section>

  <section class="section-band section-band-light" aria-labelledby="answer-heading">
    <div class="section-inner">
      <div class="answer-panel">
        <div>
          <p class="eyebrow">Direct Answer</p>
          <h2 id="answer-heading">What makes a mortgage situation complex?</h2>
        </div>
        <p>
          A mortgage situation becomes complex when the buyer needs more than a
          basic rate quote. Self-employment, bonus or commission income,
          relocation timing, VA eligibility, jumbo loan size, multiple assets,
          property questions, or a tight offer deadline can all change the best
          financing path.
        </p>
      </div>
      <div class="feature-grid">
        <article class="feature-card">
          <span>01</span>
          <h3>Income that needs explanation</h3>
          <p>
            Self-employed, bonus, commission, retirement, RSU, contractor, or
            multi-source income can require a more careful review before the
            buyer depends on a number.
          </p>
        </article>
        <article class="feature-card">
          <span>02</span>
          <h3>Assets and timing that matter</h3>
          <p>
            Equity from a sale, reserve requirements, large deposits, gift
            funds, investment accounts, or relocation timing can affect the cash
            plan and documentation path.
          </p>
        </article>
        <article class="feature-card">
          <span>03</span>
          <h3>Offers that need confidence</h3>
          <p>
            When the buyer is competing, the loan plan should support the offer:
            timeline, appraisal expectations, seller credits, contingencies, and
            communication with the agent.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="split-section" aria-labelledby="local-heading">
    <div>
      <p class="eyebrow">Local Context</p>
      <h2 id="local-heading">Huntsville buyers often have moving parts.</h2>
      <p>
        North Alabama attracts military families, engineers, executives,
        self-employed professionals, relocating buyers, and households moving
        up into higher price ranges. Those buyers do not need a generic script.
        They need a mortgage conversation that understands the file, the market,
        and the decision pressure.
      </p>
      <div class="signal-list" aria-label="Complex mortgage local planning factors">
        <span>Self-employed buyers</span>
        <span>Relocation timing</span>
        <a href="/huntsville/jumbo-loans/">Jumbo strategy</a>
        <a href="/huntsville/va-loans/">VA loan guidance</a>
      </div>
    </div>
    <div class="local-context-panel" aria-label="Complex mortgage planning factors">
      <article>
        <span>Borrower profile</span>
        <strong>Not one-size-fits-all</strong>
        <p>Income, assets, debts, employment, and loan type need to tell one clear story.</p>
      </article>
      <article>
        <span>Property and offer</span>
        <strong>Risk should be known early</strong>
        <p>Appraisal, property type, contract terms, and seller expectations can affect the path.</p>
      </article>
      <article>
        <span>Communication</span>
        <strong>Everyone needs clarity</strong>
        <p>Buyers, REALTORS®, and closing partners should understand what matters next.</p>
      </article>
    </div>
  </section>

  <section class="section-band section-band-dark" aria-labelledby="process-heading">
    <div class="section-inner">
      <div class="section-heading">
        <p class="eyebrow">Process</p>
        <h2 id="process-heading">A cleaner path for complicated files.</h2>
      </div>
      <div class="timeline-grid">
        <article>
          <span>Step 1</span>
          <h3>Name the complexity</h3>
          <p>
            Identify the income, asset, property, loan type, timing, or offer
            issue that needs attention before it creates stress.
          </p>
        </article>
        <article>
          <span>Step 2</span>
          <h3>Build the document plan</h3>
          <p>
            Gather the right file details early so the buyer is not reacting to
            avoidable documentation surprises late in the process.
          </p>
        </article>
        <article>
          <span>Step 3</span>
          <h3>Match strategy to offer</h3>
          <p>
            Align pre-approval strength, closing timeline, appraisal awareness,
            cash to close, and agent communication before negotiation.
          </p>
        </article>
        <article>
          <span>Step 4</span>
          <h3>Keep the file moving</h3>
          <p>
            Use steady communication around conditions, disclosures, appraisal,
            closing documents, and final cash to close.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section-band va-topic-band" aria-labelledby="topics-heading">
    <div class="section-inner">
      <div class="section-heading section-heading-row">
        <div>
          <p class="eyebrow">Where Strategy Helps</p>
          <h2 id="topics-heading">Mortgage questions worth solving before the pressure starts.</h2>
        </div>
        <p>
          Complex mortgage guidance is about identifying the handful of details
          that can change the loan path, offer strength, or closing experience.
        </p>
      </div>
      <div class="topic-grid">
        <article>
          <h3>Self-employed income</h3>
          <p>
            Review how income may be documented and what could affect the
            qualifying conversation before a contract is signed.
          </p>
        </article>
        <article>
          <h3>Relocation and timing</h3>
          <p>
            Coordinate job start dates, current-home sale timing, temporary
            housing, cash movement, and closing expectations.
          </p>
        </article>
        <article>
          <h3>VA or jumbo overlap</h3>
          <p>
            Know when VA benefits, larger loan amounts, reserves, or appraisal
            factors should shape the plan.
          </p>
        </article>
        <article>
          <h3>REALTOR® communication</h3>
          <p>
            Make the financing story clear enough that the buyer and agent can
            make confident decisions under offer pressure.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section-band section-band-light" aria-labelledby="faq-heading">
    <div class="section-inner">
      <div class="section-heading section-heading-row">
        <div>
          <p class="eyebrow">Complex Mortgage FAQ</p>
          <h2 id="faq-heading">Questions buyers and REALTORS® ask first.</h2>
        </div>
        <p>
          These answers are written for quick understanding by serious buyers,
          referral partners, and people evaluating Clay's mortgage guidance.
        </p>
      </div>
      <div class="faq-list">
        {
          faqs.map((faq) => (
            <article>
              <h3>{faq.question}</h3>
              <p>{faq.answer}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="split-section split-section-reverse" aria-labelledby="sources-heading">
    <div class="source-panel">
      <p class="eyebrow">Official Sources</p>
      <ul>
        <li>
          This page uses CFPB consumer resources for mortgage shopping,
          disclosures, and closing-document context. Specific loan terms require
          a formal application and lender review.
        </li>
        {
          officialSources.map((source) => (
            <li>
              <a href={source.url} rel="noopener noreferrer" target="_blank">
                {source.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
    <div>
      <p class="eyebrow">Next Step</p>
      <h2 id="sources-heading">Bring the complicated parts into the open early.</h2>
      <p>
        If your income, assets, timing, loan size, VA eligibility, or offer plan
        has moving parts, talk through it before you are under contract. A clear
        plan is easier to build before the clock starts.
      </p>
      <div class="hero-actions" aria-label="Complex mortgage guidance next steps">
        <a class="button button-primary" href={site.schedulingUrl}>Chat with Clay</a>
        <a class="button button-secondary" href={site.applicationUrl}>Start application</a>
      </div>
    </div>
  </section>
</BaseLayout>
