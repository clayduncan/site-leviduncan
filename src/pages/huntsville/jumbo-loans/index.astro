---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import {
  createBreadcrumbJsonLd,
  createFaqJsonLd,
  createMortgageServiceJsonLd,
  organizationJsonLd,
  professionalServiceJsonLd,
  personJsonLd,
} from '../../../data/schema';
import { site } from '../../../data/site';

const pagePath = '/huntsville/jumbo-loans/';
const pageUrl = new URL(pagePath, site.url).href;
const conformingLimit2026 = '$832,750';

const faqs = [
  {
    question: 'What is a jumbo loan in Huntsville, Alabama?',
    answer:
      'A jumbo loan is generally a mortgage with an original loan amount above the conforming loan limit for the property location. For 2026, FHFA lists the baseline one-unit conforming loan limit for most of the United States at $832,750.',
  },
  {
    question: 'Does a higher-priced Huntsville home always require a jumbo loan?',
    answer:
      'No. The loan amount, not just the purchase price, determines whether the mortgage is above conforming limits. Down payment size, property type, and the applicable county limit all affect whether the loan is conforming or jumbo.',
  },
  {
    question: 'Are jumbo loans harder to qualify for?',
    answer:
      'Jumbo loans can involve more detailed review because the loan amount is larger and may not fit standard conforming guidelines. Lenders commonly look closely at credit, income, assets, reserves, property type, documentation, and overall risk.',
  },
  {
    question: 'When should I talk to a lender about jumbo financing?',
    answer:
      'Talk to a lender before shopping seriously in a higher-priced range. Jumbo planning should happen early so the offer strategy, down payment, reserves, documentation, appraisal expectations, and closing timeline are clear before contract pressure begins.',
  },
  {
    question: 'Can jumbo financing matter in Madison and North Alabama?',
    answer:
      'Yes. Higher-priced homes in Huntsville, Madison, Madison County, and North Alabama can create jumbo or near-jumbo planning questions, especially when the buyer has complex income, relocation timing, larger assets, or a competitive offer situation.',
  },
];

const officialSources = [
  {
    label: 'FHFA conforming loan limit values and 2026 county files',
    url: 'https://www.fhfa.gov/data/conforming-loan-limit',
  },
];

const schema = [
  personJsonLd,
  organizationJsonLd,
  professionalServiceJsonLd,
  createMortgageServiceJsonLd({
    pageUrl,
    name: 'Jumbo Loan Guidance in Huntsville',
    description:
      'Jumbo mortgage guidance for higher-priced homes, larger loan amounts, reserves, documentation, and offer planning in Huntsville, Madison, and North Alabama.',
    serviceType: 'Jumbo mortgage loan origination',
    audience: ['jumbo buyers', 'higher-priced homebuyers', 'relocating buyers'],
  }),
  createFaqJsonLd(faqs),
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': `${pageUrl}#webpage`,
    url: pageUrl,
    name: 'Jumbo Loans in Huntsville, Alabama',
    description:
      'Jumbo mortgage guidance for higher-priced homes, complex buyers, and larger loan amounts in Huntsville, Madison, and North Alabama.',
    about: [
      { '@type': 'Thing', name: 'jumbo mortgage loans' },
      { '@type': 'Thing', name: 'conforming loan limits' },
      { '@type': 'Thing', name: 'higher-priced home financing' },
      { '@type': 'Place', name: 'Huntsville, Alabama' },
      { '@type': 'Place', name: 'Madison, Alabama' },
      { '@type': 'Place', name: 'North Alabama' },
    ],
    primaryImageOfPage: new URL('/images/clay-duncan-wbackground-1400.jpg', site.url).href,
    isPartOf: { '@id': `${site.url}/#website` },
    mainEntity: { '@id': `${site.url}/#person` },
    citation: officialSources.map((source) => source.url),
  },
  createBreadcrumbJsonLd([
    { name: 'Home', path: '/' },
    { name: 'Jumbo Loans in Huntsville', path: pagePath },
  ]),
];
---

<BaseLayout
  title="Jumbo Loans in Huntsville, AL | Higher-Priced Home Financing"
  description="Jumbo mortgage guidance for higher-priced homes, complex buyers, and larger loan amounts in Huntsville, Madison, and North Alabama."
  schema={schema}
>
  <section class="hero-section landing-hero va-landing-hero" aria-labelledby="jumbo-heading">
    <div class="hero-copy">
      <p class="eyebrow">Huntsville Jumbo Loans</p>
      <h1 id="jumbo-heading">Jumbo mortgage guidance for higher-priced Huntsville homes.</h1>
      <p class="hero-lede">
        Clay Duncan helps buyers in Huntsville, Madison, and North Alabama think
        through larger loan amounts, down payment strategy, reserves, appraisal
        expectations, and offer readiness before the contract gets complicated.
      </p>
      <div class="hero-actions" aria-label="Jumbo loan actions">
        <a class="button button-primary" href={site.schedulingUrl}>Talk through jumbo options</a>
        <a class="button button-secondary" href={site.applicationUrl}>Start a loan application</a>
      </div>
      <dl class="proof-strip" aria-label="Jumbo loan highlights">
        <div>
          <dt>2026</dt>
          <dd>{conformingLimit2026} baseline one-unit conforming limit</dd>
        </div>
        <div>
          <dt>Assets</dt>
          <dd>Reserve and documentation planning matter</dd>
        </div>
        <div>
          <dt>Offer</dt>
          <dd>Loan strategy should be clear before negotiation</dd>
        </div>
      </dl>
    </div>
    <div class="hero-media va-hero-media">
      <img
        src="/images/clay-duncan-wbackground-1400.jpg"
        width="1400"
        height="787"
        alt="Clay Duncan in a warm modern interior, Huntsville mortgage loan originator for jumbo loan guidance"
      />
      <div class="va-visual-card va-visual-card-top">
        <span>Higher-priced home financing</span>
        <strong>Loan limit, down payment, reserves, appraisal, closing</strong>
      </div>
    </div>
  </section>

  <section class="section-band section-band-light" aria-labelledby="answer-heading">
    <div class="section-inner">
      <div class="answer-panel">
        <div>
          <p class="eyebrow">Direct Answer</p>
          <h2 id="answer-heading">What makes a mortgage a jumbo loan?</h2>
        </div>
        <p>
          A jumbo loan is generally a mortgage with an original loan amount above
          the conforming loan limit for the property location. FHFA lists the
          2026 baseline one-unit conforming loan limit for most of the United
          States at {conformingLimit2026}. The loan amount, not just the purchase
          price, determines whether jumbo planning is needed.
        </p>
      </div>
      <div class="feature-grid">
        <article class="feature-card">
          <span>01</span>
          <h3>Loan amount and down payment</h3>
          <p>
            A higher purchase price may still fit conforming limits if the down
            payment is large enough. A smaller down payment on a higher-priced
            home can push the loan amount into jumbo territory.
          </p>
        </article>
        <article class="feature-card">
          <span>02</span>
          <h3>Income, assets, and reserves</h3>
          <p>
            Jumbo reviews often look closely at documentation, liquidity,
            reserves, debt ratio, income stability, and whether the full profile
            supports the larger loan request.
          </p>
        </article>
        <article class="feature-card">
          <span>03</span>
          <h3>Appraisal and offer strategy</h3>
          <p>
            Higher-priced purchases need an offer plan that accounts for
            appraisal expectations, contract timing, cash to close, and how the
            pre-approval will be understood by the seller.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="split-section" aria-labelledby="local-heading">
    <div>
      <p class="eyebrow">Local Context</p>
      <h2 id="local-heading">Huntsville’s higher-priced buyers need more than a payment quote.</h2>
      <p>
        Larger purchases around Huntsville, Madison, and North Alabama can bring
        more moving parts: equity from a prior sale, relocation timing, bonus or
        variable income, self-employment, investment assets, reserves, and
        competing offer pressure. The mortgage conversation should match that
        complexity.
      </p>
      <div class="signal-list" aria-label="Jumbo loan local planning factors">
        <span>Huntsville</span>
        <span>Madison</span>
        <span>Higher-priced homes</span>
        <span>Complex buyer strategy</span>
      </div>
    </div>
    <div class="local-context-panel" aria-label="Jumbo mortgage planning factors">
      <article>
        <span>Price point</span>
        <strong>Near or above limit</strong>
        <p>Planning starts when the loan amount may approach or exceed conforming limits.</p>
      </article>
      <article>
        <span>Documentation</span>
        <strong>More detail</strong>
        <p>Income, assets, reserves, and property details should be organized before the offer.</p>
      </article>
      <article>
        <span>Strategy</span>
        <strong>Offer confidence</strong>
        <p>The financing story should help the buyer compete without creating avoidable risk.</p>
      </article>
    </div>
  </section>

  <section class="section-band section-band-dark" aria-labelledby="process-heading">
    <div class="section-inner">
      <div class="section-heading">
        <p class="eyebrow">Process</p>
        <h2 id="process-heading">A stronger jumbo planning path.</h2>
      </div>
      <div class="timeline-grid">
        <article>
          <span>Step 1</span>
          <h3>Define the range</h3>
          <p>
            Review purchase price, down payment, loan amount, comfort level, and
            whether conforming or jumbo strategy is likely.
          </p>
        </article>
        <article>
          <span>Step 2</span>
          <h3>Organize the file</h3>
          <p>
            Look at income, assets, reserves, credit, property type, and any
            complexity that should be solved before contract pressure.
          </p>
        </article>
        <article>
          <span>Step 3</span>
          <h3>Plan the offer</h3>
          <p>
            Align pre-approval strength, appraisal risk, seller credits, closing
            timeline, and how the buyer's agent should position the offer.
          </p>
        </article>
        <article>
          <span>Step 4</span>
          <h3>Close with discipline</h3>
          <p>
            Keep underwriting, conditions, assets, appraisal, and closing
            disclosures moving with steady communication.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section-band va-topic-band" aria-labelledby="topics-heading">
    <div class="section-inner">
      <div class="section-heading section-heading-row">
        <div>
          <p class="eyebrow">What Clay Helps Clarify</p>
          <h2 id="topics-heading">Jumbo loan questions to answer before you write the offer.</h2>
        </div>
        <p>
          The goal is not just a larger pre-approval. The goal is a financing
          plan that fits the buyer, the property, the market, and the timeline.
        </p>
      </div>
      <div class="topic-grid">
        <article>
          <h3>Conforming vs. jumbo</h3>
          <p>
            Know whether the loan amount is above the applicable conforming
            limit and whether a different down payment changes the path.
          </p>
        </article>
        <article>
          <h3>Reserve requirements</h3>
          <p>
            Larger loans may require stronger liquidity planning after closing,
            not just enough cash for down payment and closing costs.
          </p>
        </article>
        <article>
          <h3>Complex income</h3>
          <p>
            Bonus, commission, self-employed, RSU, retirement, or multiple-income
            profiles need a careful review before a high-stakes offer.
          </p>
        </article>
        <article>
          <h3>Appraisal risk</h3>
          <p>
            Higher-priced homes can require more thoughtful appraisal and cash
            strategy, especially when inventory or competition is tight.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section-band section-band-light" aria-labelledby="faq-heading">
    <div class="section-inner">
      <div class="section-heading section-heading-row">
        <div>
          <p class="eyebrow">Jumbo Loan FAQ</p>
          <h2 id="faq-heading">Questions higher-priced Huntsville buyers ask first.</h2>
        </div>
        <p>
          These answers are written for quick understanding by higher-priced
          buyers and REALTORS® evaluating jumbo mortgage guidance.
        </p>
      </div>
      <div class="faq-list">
        {
          faqs.map((faq) => (
            <article>
              <h3>{faq.question}</h3>
              <p>{faq.answer}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="split-section split-section-reverse" aria-labelledby="sources-heading">
    <div class="source-panel">
      <p class="eyebrow">Official Sources</p>
      <ul>
        <li>
          This page uses FHFA source material for conforming loan limit context.
          Program requirements and lender overlays can vary.
        </li>
        {
          officialSources.map((source) => (
            <li>
              <a href={source.url} rel="noopener noreferrer" target="_blank">
                {source.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
    <div>
      <p class="eyebrow">Next Step</p>
      <h2 id="sources-heading">Talk through your higher-priced purchase plan.</h2>
      <p>
        If your loan amount may be near or above conforming limits, start the
        mortgage conversation before the offer. The earlier the strategy is
        clear, the less the purchase depends on guesswork.
      </p>
      <div class="hero-actions" aria-label="Jumbo loan next steps">
        <a class="button button-primary" href={site.schedulingUrl}>Chat with Clay</a>
        <a class="button button-secondary" href={site.applicationUrl}>Start application</a>
      </div>
    </div>
  </section>
</BaseLayout>
