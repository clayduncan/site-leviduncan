---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import {
  createBreadcrumbJsonLd,
  createFaqJsonLd,
  createMortgageServiceJsonLd,
  mortgageServices,
  organizationJsonLd,
  professionalServiceJsonLd,
  personJsonLd,
} from '../../../data/schema';
import { site } from '../../../data/site';

const pagePath = '/huntsville/mortgage-guidance/';
const pageUrl = new URL(pagePath, site.url).href;

const faqs = [
  {
    question: 'What mortgage guidance does Levi Duncan provide in Huntsville?',
    answer:
      'Levi Duncan provides mortgage guidance for first-time buyers, FHA loans, USDA loans, down payment assistance, buyer readiness, and investment property financing in Huntsville, Madison, Decatur, Athens, Madison County, Morgan County, and the Tennessee Valley.',
  },
  {
    question: 'When should a first-time homebuyer talk with Levi?',
    answer:
      'A first-time homebuyer should talk with Levi before touring homes or guessing at a budget, because early review can clarify credit, cash to close, loan program fit, and the next practical step.',
  },
];

const schema = [
  personJsonLd,
  organizationJsonLd,
  professionalServiceJsonLd,
  createMortgageServiceJsonLd({
    pageUrl,
    name: 'Mortgage Guidance in Huntsville',
    description:
      'Mortgage guidance from Levi Duncan for first-time buyers, FHA loans, USDA loans, down payment assistance, and investment property financing in Huntsville and North Alabama.',
    serviceType: 'Mortgage loan origination',
    audience: ['first-time homebuyers', 'homebuyers', 'real estate investors'],
  }),
  createFaqJsonLd(faqs),
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    '@id': `${pageUrl}#webpage`,
    url: pageUrl,
    name: 'Mortgage Guidance in Huntsville',
    description:
      'Start here for Levi Duncan mortgage guidance in Huntsville, Madison, Decatur, Athens, and the Tennessee Valley.',
    mainEntity: {
      '@type': 'ItemList',
      itemListElement: mortgageServices.map((service, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        name: service.name,
        url: new URL(service.path, site.url).href,
      })),
    },
    isPartOf: { '@id': `${site.url}/#website` },
  },
  createBreadcrumbJsonLd([
    { name: 'Home', path: '/' },
    { name: 'Mortgage Guidance in Huntsville', path: pagePath },
  ]),
];
---

<BaseLayout
  title="Mortgage Guidance | Huntsville | Levi Duncan"
  description="Start with Levi Duncan for Huntsville first-time buyer, FHA, USDA, DPA, and investment property mortgage guidance."
  schema={schema}
>
  <section class="hero-section landing-hero va-landing-hero" aria-labelledby="hub-heading">
    <div class="hero-copy">
      <p class="eyebrow">Mortgage Guidance in Huntsville</p>
      <h1 id="hub-heading">Mortgage guidance for Huntsville buyers starting smart.</h1>
      <p class="hero-lede">
        Levi Duncan helps homebuyers in Huntsville, Madison, Decatur, Athens,
        Madison County, Morgan County, and the broader Tennessee Valley compare
        practical mortgage paths before the home search creates pressure.
      </p>
      <div class="hero-actions">
        <a class="button button-primary" href={site.calendlyUrl}>Book a call with Levi</a>
        <a class="button button-secondary" href={site.applicationUrl}>Apply with Levi</a>
      </div>
    </div>
    <div class="hero-media va-hero-media">
      <img
        src={site.heroImage}
        width="800"
        height="800"
        alt="Levi Duncan, Huntsville Mortgage Loan Originator for buyer guidance"
      />
    </div>
  </section>

  <section class="section-band section-band-light" aria-labelledby="programs-heading">
    <div class="section-inner">
      <div class="section-heading section-heading-row">
        <div>
          <p class="eyebrow">Program Pages</p>
          <h2 id="programs-heading">Five Huntsville mortgage paths Levi will cover.</h2>
        </div>
        <p>
          These program pages are queued for Phase 2 and will be built one at a
          time with full AEO/SEO structure, FAQs, schema, and review gates.
        </p>
      </div>
      <div class="feature-grid">
        {
          mortgageServices.map((service, index) => (
            <article class="feature-card">
              <span>{String(index + 1).padStart(2, '0')}</span>
              <h3>{service.name}</h3>
              <p>{service.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-band section-band-light" aria-labelledby="faq-heading">
    <div class="section-inner">
      <div class="section-heading">
        <p class="eyebrow">FAQ</p>
        <h2 id="faq-heading">Mortgage guidance questions in Huntsville.</h2>
      </div>
      <div class="faq-list">
        {
          faqs.map((faq) => (
            <article>
              <h3>{faq.question}</h3>
              <p>{faq.answer}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
