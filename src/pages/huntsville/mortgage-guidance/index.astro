---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import {
  createBreadcrumbJsonLd,
  createFaqJsonLd,
  createMortgageServiceJsonLd,
  mortgageServices,
  organizationJsonLd,
  professionalServiceJsonLd,
  personJsonLd,
} from '../../../data/schema';
import { site } from '../../../data/site';

const pagePath = '/huntsville/mortgage-guidance/';
const pageUrl = new URL(pagePath, site.url).href;

const heroPaths = [
  {
    title: 'FHA Loans',
    subtitle: 'Flexible credit and down payment options',
    href: '/huntsville/mortgage-guidance/fha-loans/',
  },
  {
    title: 'USDA Loans',
    subtitle: 'Eligible rural and suburban homebuyers',
    href: '/huntsville/mortgage-guidance/usda-loans/',
  },
  {
    title: 'Down Payment Assistance',
    subtitle: 'DPA options for Alabama homebuyers',
    href: '/huntsville/mortgage-guidance/down-payment-assistance/',
  },
  {
    title: 'Investment Property',
    subtitle: 'DSCR and rental-property financing',
    href: '/huntsville/mortgage-guidance/investment-property/',
  },
];

const faqs = [
  {
    question: 'What mortgage guidance does Levi Duncan provide in Huntsville?',
    answer: `${site.serviceAreaStatement} He provides mortgage guidance for first-time buyers, FHA loans, USDA loans, down payment assistance, buyer readiness, and investment property financing.`,
  },
  {
    question: 'When should a first-time homebuyer talk with Levi?',
    answer:
      'A first-time homebuyer should talk with Levi before touring homes or guessing at a budget, because early review can clarify credit, cash to close, loan program fit, and the next practical step.',
  },
];

const guidanceAnswers = [
  {
    question: 'What should first-time buyers compare first?',
    answer:
      'First-time buyers should compare payment comfort, cash to close, credit position, documents, and loan program fit before touring homes. That early review helps a buyer understand whether FHA, USDA, First Step assistance, conventional financing, or another path deserves a closer look.',
  },
  {
    question: 'Which mortgage paths does Levi help buyers compare?',
    answer:
      'Levi helps buyers compare first-time homebuyer guidance, FHA loans, USDA loans, Alabama First Step down payment assistance, and investment property options. The goal is to match the mortgage path to the buyer profile, property type, location, timeline, and cash available before pressure builds.',
  },
  {
    question: 'Why start before the home search?',
    answer:
      'Starting before the home search gives buyers time to review budget, credit, documents, property expectations, and approval strength without an offer deadline. That makes it easier to ask better questions and avoid last-minute financing surprises during inspection, appraisal, underwriting, or closing.',
  },
];

const schema = [
  personJsonLd,
  organizationJsonLd,
  professionalServiceJsonLd,
  createMortgageServiceJsonLd({
    pageUrl,
    name: 'Mortgage Guidance in Huntsville',
    description:
      'Mortgage guidance from Levi Duncan for first-time buyers, FHA loans, USDA loans, down payment assistance, and investment property financing across Madison, Decatur, Athens, Albertville, Arab, and the wider Tennessee Valley.',
    serviceType: 'Mortgage loan origination',
    audience: ['first-time homebuyers', 'homebuyers', 'real estate investors'],
  }),
  createFaqJsonLd(faqs),
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    '@id': `${pageUrl}#webpage`,
    url: pageUrl,
    name: 'Mortgage Guidance in Huntsville',
    description: `Start here for Levi Duncan mortgage guidance. ${site.serviceAreaStatement}`,
    mainEntity: {
      '@type': 'ItemList',
      itemListElement: mortgageServices.map((service, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        name: service.name,
        url: new URL(service.path, site.url).href,
      })),
    },
    isPartOf: { '@id': `${site.url}/#website` },
  },
  createBreadcrumbJsonLd([
    { name: 'Home', path: '/' },
    { name: 'Mortgage Guidance in Huntsville', path: pagePath },
  ]),
];
---

<BaseLayout
  title="Mortgage Guidance | Huntsville | Levi Duncan"
  description="Start with Levi Duncan for Huntsville first-time buyer, FHA, USDA, DPA, and investment property mortgage guidance."
  schema={schema}
>
  <section class="hero-section landing-hero va-landing-hero" aria-labelledby="hub-heading">
    <div class="hero-copy">
      <p class="eyebrow">Mortgage Guidance in Huntsville</p>
      <h1 id="hub-heading">Mortgage guidance for Huntsville buyers starting smart.</h1>
      <p class="hero-lede">
        {site.serviceAreaStatement}
      </p>
      <div class="hero-actions" aria-label="Mortgage guidance actions">
        <a class="button button-primary" href={site.calendlyUrl}>Talk through your scenario</a>
        <a class="button button-secondary" href={site.applicationUrl}>Start a loan application</a>
      </div>
      <div class="hero-path-grid" aria-label="Levi Duncan mortgage specialties">
        {
          heroPaths.map((path) => (
            path.href ? (
              <a href={path.href}>
                <strong>{path.title}</strong>
                <span>{path.subtitle}</span>
              </a>
            ) : (
              <div>
                <strong>{path.title}</strong>
                <span>{path.subtitle}</span>
              </div>
            )
          ))
        }
      </div>
    </div>
    <div class="hero-media va-hero-media mortgage-hub-hero-media">
      <img
        src={site.heroImage}
        width="800"
        height="800"
        alt="Levi Duncan, Huntsville Mortgage Loan Originator for buyer guidance"
      />
      <div class="va-visual-card va-visual-card-top">
        <span>{site.tagline}</span>
        <strong>FHA, USDA, down payment assistance, and DSCR guidance</strong>
      </div>
      <div class="hero-path-grid first-time-guidance-card">
        <a href="/huntsville/mortgage-guidance/first-time-home-buyer/">
          <strong>First-Time Home Buyer Guidance</strong>
          <span>
            Start here for payment comfort, cash to close, loan options, documents, and first-offer readiness.
          </span>
        </a>
      </div>
    </div>
  </section>

  <section class="section-band section-band-light" aria-labelledby="first-time-heading">
    <div class="split-section">
      <div>
        <p class="eyebrow">First-Time Homebuyers</p>
        <h2 id="first-time-heading">Make the first mortgage decision easier to understand.</h2>
        <p>
          First-time homebuyers need a simple starting point: what payment range
          makes sense, how much cash may be needed, which loan options fit, and
          what to do next before the home search gets serious. Levi helps buyers
          turn those early questions into a practical plan.
        </p>
        <div class="hero-actions" aria-label="First-time homebuyer actions">
          <a class="button button-primary" href={site.calendlyUrl}>Book a buyer consultation</a>
          <a class="button button-secondary" href="/events/">Check Homebuyer Master Class events</a>
        </div>
      </div>
      <div class="local-context-panel" aria-label="First-time homebuyer priorities">
        <article>
          <span>Budget</span>
          <strong>Know the payment before the search</strong>
          <p>
            Compare approval range, monthly payment comfort, cash to close, and
            reserves so the home search starts with a realistic number.
          </p>
        </article>
        <article>
          <span>Readiness</span>
          <strong>Avoid mistakes before closing</strong>
          <p>
            Talk through credit, income, documents, deposits, job changes, and
            large purchases before they create underwriting problems.
          </p>
        </article>
        <article>
          <span>Confidence</span>
          <strong>Understand the full buying team</strong>
          <p>
            See how financing, offer strategy, inspection, insurance, title,
            and closing all work together before keys transfer.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section-band" aria-labelledby="answer-heading">
    <div class="section-inner">
      <div class="section-heading section-heading-wide events-section-heading">
        <p class="eyebrow">Quick Answers</p>
        <h2 id="answer-heading">What should buyers understand before choosing a mortgage path?</h2>
      </div>
      <div class="faq-list answer-list">
        {
          guidanceAnswers.map((item) => (
            <article>
              <h3>{item.question}</h3>
              <p>{item.answer}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-band section-band-white" aria-labelledby="faq-heading">
    <div class="section-inner">
      <div class="section-heading">
        <p class="eyebrow">FAQ</p>
        <h2 id="faq-heading">Mortgage guidance questions in Huntsville.</h2>
      </div>
      <div class="faq-list">
        {
          faqs.map((faq) => (
            <article>
              <h3>{faq.question}</h3>
              <p>{faq.answer}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
