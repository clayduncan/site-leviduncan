---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import {
  createBreadcrumbJsonLd,
  createFaqJsonLd,
  createMortgageServiceJsonLd,
  mortgageServices,
  organizationJsonLd,
  professionalServiceJsonLd,
  personJsonLd,
} from '../../../data/schema';
import { site } from '../../../data/site';

const pagePath = '/huntsville/mortgage-guidance/';
const pageUrl = new URL(pagePath, site.url).href;

const heroPaths = [
  {
    title: 'FHA Loans',
    subtitle: 'Flexible credit and down payment options',
  },
  {
    title: 'USDA Loans',
    subtitle: 'Eligible rural and suburban homebuyers',
  },
  {
    title: 'Down Payment Assistance',
    subtitle: 'DPA options for Alabama homebuyers',
  },
  {
    title: 'Investment Property',
    subtitle: 'DSCR and rental-property financing',
  },
];

const faqs = [
  {
    question: 'What mortgage guidance does Levi Duncan provide in Huntsville?',
    answer:
      'Levi Duncan provides mortgage guidance for first-time buyers, FHA loans, USDA loans, down payment assistance, buyer readiness, and investment property financing in Huntsville, Madison, Decatur, Athens, Madison County, Morgan County, and the Tennessee Valley.',
  },
  {
    question: 'When should a first-time homebuyer talk with Levi?',
    answer:
      'A first-time homebuyer should talk with Levi before touring homes or guessing at a budget, because early review can clarify credit, cash to close, loan program fit, and the next practical step.',
  },
];

const schema = [
  personJsonLd,
  organizationJsonLd,
  professionalServiceJsonLd,
  createMortgageServiceJsonLd({
    pageUrl,
    name: 'Mortgage Guidance in Huntsville',
    description:
      'Mortgage guidance from Levi Duncan for first-time buyers, FHA loans, USDA loans, down payment assistance, and investment property financing in Huntsville and North Alabama.',
    serviceType: 'Mortgage loan origination',
    audience: ['first-time homebuyers', 'homebuyers', 'real estate investors'],
  }),
  createFaqJsonLd(faqs),
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    '@id': `${pageUrl}#webpage`,
    url: pageUrl,
    name: 'Mortgage Guidance in Huntsville',
    description:
      'Start here for Levi Duncan mortgage guidance in Huntsville, Madison, Decatur, Athens, and the Tennessee Valley.',
    mainEntity: {
      '@type': 'ItemList',
      itemListElement: mortgageServices.map((service, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        name: service.name,
        url: new URL(service.path, site.url).href,
      })),
    },
    isPartOf: { '@id': `${site.url}/#website` },
  },
  createBreadcrumbJsonLd([
    { name: 'Home', path: '/' },
    { name: 'Mortgage Guidance in Huntsville', path: pagePath },
  ]),
];
---

<BaseLayout
  title="Mortgage Guidance | Huntsville | Levi Duncan"
  description="Start with Levi Duncan for Huntsville first-time buyer, FHA, USDA, DPA, and investment property mortgage guidance."
  schema={schema}
>
  <section class="hero-section landing-hero va-landing-hero" aria-labelledby="hub-heading">
    <div class="hero-copy">
      <p class="eyebrow">Mortgage Guidance in Huntsville</p>
      <h1 id="hub-heading">Mortgage guidance for Huntsville buyers starting smart.</h1>
      <p class="hero-lede">
        Levi Duncan helps homebuyers across Madison, Decatur, Athens,
        Albertville, Arab, and the wider Tennessee Valley compare practical
        mortgage paths before the home search creates pressure, serving Madison
        County, Marshall County, and Morgan County across North Alabama.
      </p>
      <div class="hero-actions" aria-label="Mortgage guidance actions">
        <a class="button button-primary" href={site.calendlyUrl}>Talk through your scenario</a>
        <a class="button button-secondary" href={site.applicationUrl}>Start a loan application</a>
      </div>
      <div class="hero-path-grid" aria-label="Levi Duncan mortgage specialties">
        {
          heroPaths.map((path) => (
            <div>
              <strong>{path.title}</strong>
              <span>{path.subtitle}</span>
            </div>
          ))
        }
      </div>
    </div>
    <div class="hero-media va-hero-media">
      <img
        src={site.heroImage}
        width="800"
        height="800"
        alt="Levi Duncan, Huntsville Mortgage Loan Originator for buyer guidance"
      />
    </div>
  </section>

  <section class="split-section" aria-labelledby="first-time-heading">
    <div>
      <p class="eyebrow">First-Time Homebuyers</p>
      <h2 id="first-time-heading">Make the first mortgage decision easier to understand.</h2>
      <p>
        First-time homebuyers usually do not need more noise. They need a clear
        look at budget, credit, cash to close, payment comfort, and which loan
        path fits before they start reacting to listings. Levi helps buyers turn
        the early questions into a practical plan.
      </p>
      <div class="hero-actions" aria-label="First-time homebuyer actions">
        <a class="button button-primary" href={site.calendlyUrl}>Book a buyer consultation</a>
        <a class="button button-secondary" href="/events/">Check Homebuyer Master Class events</a>
      </div>
    </div>
    <div class="local-context-panel" aria-label="First-time homebuyer priorities">
      <article>
        <span>Budget</span>
        <strong>Know the number before the search</strong>
        <p>
          Clarify payment comfort, cash to close, and the difference between
          what is possible and what feels responsible.
        </p>
      </article>
      <article>
        <span>Readiness</span>
        <strong>Turn questions into next steps</strong>
        <p>
          Review credit, income, savings, documents, and timeline before a home
          search creates pressure.
        </p>
      </article>
      <article>
        <span>Programs</span>
        <strong>Compare FHA, USDA, and DPA fit</strong>
        <p>
          Match the buyer's situation to realistic loan options instead of
          guessing which program should come first.
        </p>
      </article>
    </div>
  </section>

  <section class="section-band section-band-light" aria-labelledby="faq-heading">
    <div class="section-inner">
      <div class="section-heading">
        <p class="eyebrow">FAQ</p>
        <h2 id="faq-heading">Mortgage guidance questions in Huntsville.</h2>
      </div>
      <div class="faq-list">
        {
          faqs.map((faq) => (
            <article>
              <h3>{faq.question}</h3>
              <p>{faq.answer}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
