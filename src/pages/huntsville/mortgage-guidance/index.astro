---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import {
  createBreadcrumbJsonLd,
  createFaqJsonLd,
  createMortgageServiceJsonLd,
  organizationJsonLd,
  professionalServiceJsonLd,
  personJsonLd,
} from '../../../data/schema';
import { site } from '../../../data/site';

const pagePath = '/huntsville/mortgage-guidance/';
const pageUrl = new URL(pagePath, site.url).href;

const faqs = [
  {
    question: 'What mortgage guidance does Clay Duncan provide in Huntsville?',
    answer:
      'Clay Duncan provides mortgage guidance for VA loans near Redstone Arsenal, jumbo and higher-priced home purchases, medical professional mortgage options, and complex mortgage scenarios for buyers across Huntsville, Madison, and North Alabama.',
  },
  {
    question: 'Where should I start if I am a military buyer near Redstone Arsenal?',
    answer:
      'Start with Clay Duncan’s VA loan guidance for Huntsville and Redstone Arsenal-area military buyers. That page explains VA eligibility, COE questions, zero-down financing, funding fees, and local planning considerations.',
  },
  {
    question: 'When should I use complex mortgage guidance?',
    answer:
      'Complex mortgage guidance is useful when the file involves self-employment, variable income, relocation timing, multiple properties, large assets, jumbo financing, VA eligibility, appraisal risk, or a tight contract timeline.',
  },
  {
    question: 'Does Clay Duncan help medical professionals buying in Huntsville?',
    answer:
      'Yes. Clay Duncan helps eligible medical professionals, including doctors, dentists, pharmacists, veterinarians, residents, fellows, and other qualified healthcare professionals, evaluate specialty mortgage options for Huntsville, Madison, and North Alabama home purchases.',
  },
];

const schema = [
  personJsonLd,
  organizationJsonLd,
  professionalServiceJsonLd,
  createMortgageServiceJsonLd({
    pageUrl,
    name: 'Mortgage Guidance in Huntsville and North Alabama',
    description:
      'Mortgage guidance for VA loans, jumbo loans, medical professional mortgages, and complex mortgage planning in Huntsville, Madison, Redstone Arsenal, and North Alabama.',
    serviceType: 'Mortgage loan origination',
    audience: ['homebuyers', 'VA-eligible borrowers', 'jumbo buyers', 'medical professionals'],
  }),
  createFaqJsonLd(faqs),
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    '@id': `${pageUrl}#webpage`,
    url: pageUrl,
    name: 'Mortgage Guidance in Huntsville, Alabama',
    description:
      'Start here for Clay Duncan mortgage guidance in Huntsville, including VA loans near Redstone Arsenal, jumbo loan strategy, medical professional mortgage options, and complex mortgage planning.',
    about: [
      { '@type': 'Thing', name: 'Huntsville mortgage guidance' },
      { '@type': 'Thing', name: 'VA loans near Redstone Arsenal' },
      { '@type': 'Thing', name: 'jumbo loan strategy' },
      { '@type': 'Thing', name: 'medical professional mortgage' },
      { '@type': 'Thing', name: 'complex mortgage guidance' },
      { '@type': 'Place', name: 'Huntsville, Alabama' },
      { '@type': 'Place', name: 'Madison, Alabama' },
      { '@type': 'Place', name: 'North Alabama' },
    ],
    hasPart: [
      {
        '@type': 'WebPage',
        name: 'VA Loans in Huntsville',
        url: `${site.url}/huntsville/va-loans/`,
      },
      {
        '@type': 'WebPage',
        name: 'Jumbo Loans in Huntsville',
        url: `${site.url}/huntsville/jumbo-loans/`,
      },
      {
        '@type': 'WebPage',
        name: 'Medical Professional Mortgage in Huntsville',
        url: `${site.url}/huntsville/medical-professional-mortgage/`,
      },
      {
        '@type': 'WebPage',
        name: 'Complex Mortgage Guidance in Huntsville',
        url: `${site.url}/huntsville/complex-mortgage-guidance/`,
      },
    ],
    primaryImageOfPage: new URL('/images/clay-duncan-wbackground-1400.jpg', site.url).href,
    isPartOf: { '@id': `${site.url}/#website` },
    mainEntity: { '@id': `${site.url}/#person` },
  },
  createBreadcrumbJsonLd([
    { name: 'Home', path: '/' },
    { name: 'Mortgage Guidance in Huntsville', path: pagePath },
  ]),
];
---

<BaseLayout
  title="Mortgage Guidance in Huntsville, AL | VA, Jumbo, Medical, Complex"
  description="Start here for Clay Duncan mortgage guidance in Huntsville, including VA loans near Redstone Arsenal, jumbo loans, medical professional mortgages, and complex planning."
  schema={schema}
>
  <section class="hero-section landing-hero va-landing-hero" aria-labelledby="mortgage-hub-heading">
    <div class="hero-copy">
      <p class="eyebrow">Mortgage Hub</p>
      <h1 id="mortgage-hub-heading">Start with the mortgage path that matches the decision in front of you.</h1>
      <p class="hero-lede">
        Clay Duncan helps Huntsville, Madison, Redstone Arsenal, and North
        Alabama buyers clarify the right next step for VA loans, jumbo
        purchases, medical professional mortgage options, and complex mortgage
        questions before the pressure of an offer or closing timeline.
      </p>
      <div class="hero-actions" aria-label="Mortgage guidance actions">
        <a class="button button-primary" href={site.schedulingUrl}>Talk through your scenario</a>
        <a class="button button-secondary" href={site.applicationUrl}>Start a loan application</a>
      </div>
      <div class="hero-path-grid" aria-label="Mortgage guidance paths">
        <a href="/huntsville/va-loans/">
          <strong>VA</strong>
          <span>Redstone Arsenal-area military buyers</span>
        </a>
        <a href="/huntsville/jumbo-loans/">
          <strong>Jumbo</strong>
          <span>Higher-priced home strategy</span>
        </a>
        <a href="/huntsville/medical-professional-mortgage/">
          <strong>Medical</strong>
          <span>Specialty guidance for eligible professionals</span>
        </a>
        <a href="/huntsville/complex-mortgage-guidance/">
          <strong>Complex</strong>
          <span>Income, assets, timing, and offer planning</span>
        </a>
      </div>
    </div>
    <div class="hero-media va-hero-media">
      <img
        src="/images/clay-duncan-wbackground-1400.jpg"
        width="1400"
        height="787"
        alt="Clay Duncan, Huntsville mortgage loan originator for VA, jumbo, and complex mortgage guidance"
      />
      <div class="va-visual-card va-visual-card-top">
        <span>{site.tagline}</span>
        <strong>VA loans, jumbo strategy, medical professionals, and complex guidance</strong>
      </div>
    </div>
  </section>

  <section class="section-band section-band-light" aria-labelledby="answer-heading">
    <div class="section-inner">
      <div class="answer-panel">
        <div>
          <p class="eyebrow">Direct Answer</p>
          <h2 id="answer-heading">What mortgage guidance does Clay Duncan provide?</h2>
        </div>
        <div>
          <p>
            Clay Duncan provides Huntsville mortgage guidance for VA loans near
            Redstone Arsenal, jumbo and higher-priced home purchases, medical
            professional mortgage options, and complex mortgage scenarios where
            income, assets, timing, documentation, or offer strategy need to be
            clarified early.
          </p>
          <div class="signal-list" aria-label="Mortgage guidance topics">
            <a href="/huntsville/va-loans/">VA loan guidance</a>
            <a href="/huntsville/jumbo-loans/">Jumbo loan strategy</a>
            <a href="/huntsville/medical-professional-mortgage/">Medical professional mortgage</a>
            <a href="/huntsville/complex-mortgage-guidance/">Complex mortgage planning</a>
          </div>
        </div>
      </div>
      <div class="local-context-panel local-context-panel-row" aria-label="Mortgage guidance fit signals">
        <article>
          <span>VA loans</span>
          <strong>VA loans near Redstone Arsenal</strong>
          <p>Understand eligibility, zero-down options, funding fees, closing costs, and timing.</p>
        </article>
        <article>
          <span>Jumbo loans</span>
          <strong>Jumbo loans for higher-priced homes</strong>
          <p>Plan around reserves, documentation, appraisal expectations, and cash to close.</p>
        </article>
        <article>
          <span>Medical professional loans</span>
          <strong>Medical professional loans</strong>
          <p>Relocation, offer letters, student loans, residency, fellowship, and contract income matter.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section-band section-band-dark" aria-labelledby="local-heading">
    <div class="section-inner">
      <div class="section-heading section-heading-row">
        <div>
          <p class="eyebrow">Local Signal</p>
          <h2 id="local-heading">Built for Huntsville, Madison, Redstone Arsenal, and North Alabama.</h2>
        </div>
        <p>
          The mortgage hub gives people and search systems one clear place to
          understand Clay’s mortgage focus before choosing the VA, jumbo,
          medical professional, or complex guidance page that matches their
          situation.
        </p>
      </div>
      <div class="dark-signal-grid" aria-label="Mortgage guidance local signals">
        <article>
          <span>Huntsville + Madison</span>
          <h3>Local mortgage planning</h3>
          <p>Guidance for buyers across the core North Alabama market.</p>
        </article>
        <article>
          <span>Redstone Arsenal</span>
          <h3>Military buyer context</h3>
          <p>VA-focused guidance for borrowers relocating, buying, or planning near Huntsville.</p>
        </article>
        <article>
          <span>North Alabama</span>
          <h3>Offer-ready strategy</h3>
          <p>Support for documentation, timing, loan structure, and clear next steps.</p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
