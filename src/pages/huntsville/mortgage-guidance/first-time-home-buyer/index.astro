---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import {
  createBreadcrumbJsonLd,
  createFaqJsonLd,
  createMortgageServiceJsonLd,
  organizationJsonLd,
  personJsonLd,
} from '../../../../data/schema';
import { site } from '../../../../data/site';

const pagePath = '/huntsville/mortgage-guidance/first-time-home-buyer/';
const pageUrl = new URL(pagePath, site.url).href;

const readinessQuestions = [
  {
    label: 'Monthly comfort',
    title: 'What payment still leaves room to live?',
    description:
      'A buyer needs to know the payment that works after utilities, savings, debt, groceries, maintenance, and life outside the mortgage.',
  },
  {
    label: 'Cash plan',
    title: 'What money is needed before keys?',
    description:
      'Down payment is only one piece. Closing costs, inspections, appraisal, insurance, reserves, moving costs, and setup costs all need a place in the plan.',
  },
  {
    label: 'Timeline',
    title: 'How ready are you to write an offer?',
    description:
      'The right timeline depends on documents, credit, savings, lease timing, job stability, and how quickly the buyer can respond once a home fits.',
  },
];

const reviewItems = [
  {
    title: 'Payment comfort and approval range',
    description:
      'Separate what a buyer may qualify for from what actually feels comfortable each month.',
  },
  {
    title: 'Cash to close and reserves',
    description:
      'Estimate likely funds needed for down payment, closing costs, prepaid items, and money left after closing.',
  },
  {
    title: 'Credit and debt positioning',
    description:
      'Review current debts, credit history, and avoidable changes that could affect approval strength.',
  },
  {
    title: 'Documents and income story',
    description:
      'Know which pay stubs, bank statements, tax documents, employment details, and deposit explanations may be needed.',
  },
  {
    title: 'Loan program comparison',
    description:
      'Compare FHA, USDA, conventional, and First Step assistance based on the buyer’s real scenario.',
  },
];

const offerReadiness = [
  {
    label: 'Preapproval',
    title: 'Strength before speed',
    description:
      'A stronger offer starts with a cleaner buyer file, not just a quick letter. Sellers and agents need confidence that the financing can close.',
  },
  {
    label: 'Conditions',
    title: 'Know what can still change',
    description:
      'A buyer should understand that appraisal, inspection, insurance, title, employment, assets, and credit can still matter after an offer is accepted.',
  },
  {
    label: 'Communication',
    title: 'Respond fast when it counts',
    description:
      'The smoothest closings usually come from buyers who know what documents may be requested and respond quickly when the file moves.',
  },
];

const dosAndDonts = [
  {
    title: 'Do talk through payment comfort early',
    description:
      'A preapproval number is not the same thing as a comfortable monthly payment. Start with the budget you can live with.',
  },
  {
    title: 'Do keep documents and deposits clean',
    description:
      'Pay stubs, bank statements, tax documents, and large deposits can all matter. Clean records make underwriting easier.',
  },
  {
    title: 'Don’t open new debt during the process',
    description:
      'New credit cards, car loans, furniture financing, or large purchases can change approval strength before closing.',
  },
  {
    title: 'Don’t skip insurance and inspection timing',
    description:
      'Insurance quotes and inspection findings can affect cost, negotiation, and closing readiness. Handle both early.',
  },
];

const faqs = [
  {
    question: 'What should a first-time homebuyer do first in Huntsville?',
    answer:
      'A first-time homebuyer should start by reviewing payment comfort, credit, savings, income, debt, and likely cash to close before touring homes. Levi Duncan helps buyers compare the practical mortgage path before the search creates pressure.',
  },
  {
    question: 'What is Levi’s 101 In-depth Homebuyer Review?',
    answer:
      'Levi’s 101 In-depth Homebuyer Review is a buyer consultation for walking through budget, documents, loan options, timeline, and next steps before a first-time buyer gets serious about offers.',
  },
  {
    question: 'Should first-time buyers attend the Homebuyer Master Class?',
    answer:
      'Yes. The Homebuyer Master Class is built for first-time and experienced buyers who want to understand financing, property strategy, inspection, insurance, title, legal, and closing topics before making a move.',
  },
  {
    question: 'Which loan options should first-time buyers compare?',
    answer:
      'First-time buyers may need to compare FHA, USDA, conventional, First Step down payment assistance, and other options depending on credit, income, property location, down payment, and long-term goals.',
  },
  {
    question: 'What mistakes should first-time buyers avoid before closing?',
    answer:
      'Common mistakes include opening new debt, making large undocumented deposits, changing jobs without guidance, skipping insurance timing, ignoring inspection concerns, or shopping homes before knowing payment comfort.',
  },
];

const schema = [
  personJsonLd,
  organizationJsonLd,
  createMortgageServiceJsonLd({
    pageUrl,
    name: 'First-Time Home Buyer Guidance in Huntsville',
    description:
      'First-time homebuyer guidance from Levi Duncan for buyers across Madison, Decatur, Athens, Albertville, Arab, and the wider Tennessee Valley comparing budget, loan options, Homebuyer Master Class events, and next steps.',
    serviceType: 'First-time homebuyer mortgage guidance',
    audience: ['first-time homebuyers', 'homebuyers'],
  }),
  createFaqJsonLd(faqs),
  createBreadcrumbJsonLd([
    { name: 'Home', path: '/' },
    { name: 'Mortgage Guidance in Huntsville', path: '/huntsville/mortgage-guidance/' },
    { name: 'First-Time Home Buyer', path: pagePath },
  ]),
];
---

<BaseLayout
  title="First-Time Home Buyer | Huntsville | Levi Duncan"
  description="Start first-time homebuyer guidance with Levi Duncan for Huntsville-area budget, loan options, buyer readiness, and next steps."
  schema={schema}
>
  <section class="hero-section landing-hero va-landing-hero" aria-labelledby="first-time-heading">
    <div class="hero-copy">
      <p class="eyebrow">First-Time Home Buyer Guidance</p>
      <h1 id="first-time-heading">First-time homebuyer guidance in Huntsville.</h1>
      <p class="hero-lede">
        {site.serviceAreaStatement} First-time homebuyer guidance helps buyers
        separate excitement from readiness, understand what they can afford,
        identify what could slow approval, and know what to have in place before
        they write their first offer.
      </p>
      <div class="hero-actions" aria-label="First-time homebuyer actions">
        <a class="button button-primary" href={site.calendlyUrl}>
          Book Levi's 101 Homebuyer Review
        </a>
        <a class="button button-secondary" href="/events/">View Homebuyer Master Class events</a>
      </div>
    </div>
    <div class="hero-media va-hero-media">
      <img
        src={site.heroImage}
        width="800"
        height="800"
        alt="Levi Duncan, Mortgage Loan Originator for first-time homebuyer guidance in Huntsville"
      />
      <div class="va-visual-card va-visual-card-top">
        <span>{site.tagline}</span>
        <strong>First-time buyer guidance and Homebuyer Master Class events</strong>
      </div>
    </div>
  </section>

  <section class="section-band section-band-light" aria-labelledby="readiness-heading">
    <div class="split-section">
      <div>
        <p class="eyebrow">Buyer Readiness</p>
        <h2 id="readiness-heading">Three questions to answer before touring homes.</h2>
        <p>
          A first-time buyer does not need to know everything before getting
          started, but they do need to understand the pressure points. The 101
          review is built to turn the unknowns into a short list of numbers,
          documents, and next steps.
        </p>
        <div class="hero-actions" aria-label="First-time buyer consultation actions">
          <a class="button button-primary" href={site.calendlyUrl}>
            Connect with Levi
          </a>
          <a class="button button-secondary" href="/events/">Attend a Homebuyer Master Class</a>
        </div>
      </div>
      <div class="local-context-panel" aria-label="First-time homebuyer readiness questions">
        {
          readinessQuestions.map((priority) => (
            <article>
              <span>{priority.label}</span>
              <strong>{priority.title}</strong>
              <p>{priority.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-band" aria-labelledby="review-heading">
    <div class="section-inner">
      <div class="section-heading section-heading-wide events-section-heading">
        <p class="eyebrow">Levi's 101 Review</p>
        <h2 id="review-heading">What should be reviewed before a first offer?</h2>
      </div>
      <div class="feature-grid feature-grid-five">
        {
          reviewItems.map((topic) => (
            <article class="feature-card">
              <span>Review</span>
              <h3>{topic.title}</h3>
              <p>{topic.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-band section-band-light" aria-labelledby="dos-heading">
    <div class="section-inner">
      <div class="section-heading section-heading-wide events-section-heading">
        <p class="eyebrow">Do's and Don'ts</p>
        <h2 id="dos-heading">First-time homebuyer best practices before an offer.</h2>
      </div>
      <div class="feature-grid feature-grid-four">
        {
          dosAndDonts.map((item, index) => (
            <article class="feature-card">
              <span>{String(index + 1).padStart(2, '0')}</span>
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-band" aria-labelledby="offer-heading">
    <div class="section-inner">
      <div class="section-heading section-heading-wide events-section-heading">
        <p class="eyebrow">Offer Readiness</p>
        <h2 id="offer-heading">What makes a first-time buyer easier to help?</h2>
      </div>
      <div class="feature-grid">
        {
          offerReadiness.map((item) => (
            <article class="feature-card">
              <span>{item.label}</span>
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-band section-band-light" aria-labelledby="faq-heading">
    <div class="section-inner">
      <div class="section-heading">
        <p class="eyebrow">FAQ</p>
        <h2 id="faq-heading">First-time homebuyer questions in Huntsville.</h2>
      </div>
      <div class="faq-list">
        {
          faqs.map((faq) => (
            <article>
              <h3>{faq.question}</h3>
              <p>{faq.answer}</p>
            </article>
          ))
        }
      </div>
      <div class="cta-band">
        <div class="section-cta-row">
          <div>
            <p class="eyebrow">Next Step</p>
            <h2>Start with a clear buyer review before the home search gets serious.</h2>
          </div>
          <div class="hero-actions" aria-label="First-time homebuyer next steps">
            <a class="button button-primary" href={site.calendlyUrl}>
              Book Levi's 101 Homebuyer Review
            </a>
            <a class="button button-secondary" href="/events/">View Homebuyer Master Class events</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
