---
import BaseLayout from '../layouts/BaseLayout.astro';
import { events, pastEvents, upcomingEvents } from '../data/events';
import {
  createBreadcrumbJsonLd,
  createEventJsonLd,
  organizationJsonLd,
  personJsonLd,
} from '../data/schema';
import { site } from '../data/site';

const formatEventDate = (date: string) =>
  new Intl.DateTimeFormat('en', {
    weekday: 'short',
    month: 'short',
    day: 'numeric',
    year: 'numeric',
    hour: 'numeric',
    minute: '2-digit',
    timeZone: 'America/Chicago',
  }).format(new Date(date));

const eventAddress = (event: (typeof events)[number]) =>
  event.address
    ? `${event.venue}, ${event.address.streetAddress}, ${event.city}, ${event.state} ${event.address.postalCode}`
    : `${event.venue}, ${event.city}, ${event.state}`;

const getRegistrationUrl = (event: (typeof events)[number]) =>
  event.registrationUrl ?? site.calendlyUrl;

const classTopics = [
  {
    label: 'Property Strategy',
    title: 'How to shop with a plan',
    description:
      'Buyers learn how representation, offer terms, contingencies, timing, and local market context shape a stronger home search.',
  },
  {
    label: 'Financing',
    title: 'How approval really works',
    description:
      'The class explains credit, income, assets, loan options, payment comfort, cash to close, and common mistakes that can delay closing.',
  },
  {
    label: 'Inspection',
    title: 'How to understand the home',
    description:
      'A home inspection helps buyers understand roof, HVAC, plumbing, electrical, safety, and repair considerations before final decisions.',
  },
  {
    label: 'Insurance',
    title: 'How to protect the property',
    description:
      'Buyers hear how homeowners insurance, coverage quality, deductibles, special property risks, and lender timing fit into closing.',
  },
  {
    label: 'Title & Legal',
    title: 'How ownership becomes clear',
    description:
      'Title and closing topics include ownership rights, title search, title insurance, closing documents, and what happens before keys transfer.',
  },
];

const schema = [
  personJsonLd,
  organizationJsonLd,
  ...events.map((event) => createEventJsonLd(event)),
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    '@id': `${site.url}/events/#webpage`,
    url: `${site.url}/events/`,
    name: 'Homebuyer Master Class',
    description:
      'Homebuyer Master Class events for Huntsville-area first-time and experienced homebuyers.',
    mainEntity: events.map((event) => ({ '@id': `${site.url}/events/#${event.id}` })),
    isPartOf: { '@id': `${site.url}/#website` },
  },
  createBreadcrumbJsonLd([
    { name: 'Home', path: '/' },
    { name: 'Events', path: '/events/' },
  ]),
];
---

<BaseLayout
  title="Homebuyer Master Class | Huntsville | Levi Duncan"
  description="View Levi Duncan's Homebuyer Master Class events for Huntsville-area first-time and experienced homebuyers."
  schema={schema}
>
  <section class="hero-section landing-hero va-landing-hero" aria-labelledby="events-heading">
    <div class="hero-copy">
      <p class="eyebrow">Events</p>
      <h1 id="events-heading">Homebuyer Master Class in Huntsville.</h1>
      <p class="hero-lede">
        Homebuyer Master Class is a monthly Huntsville-area education series for
        first-time and experienced buyers. Sessions bring together property
        strategy, title and legal, home inspection, homeowners insurance, and
        financing strategy so buyers can understand the full path before making
        a move.
      </p>
      <div class="hero-actions">
        <a class="button button-primary" href={site.calendlyUrl}>Book a call with Levi</a>
        <a class="button button-secondary" href={site.applicationUrl}>Apply with Levi</a>
      </div>
    </div>
    <div class="hero-media va-hero-media">
      <img
        src={site.heroImage}
        width="800"
        height="800"
        alt="Levi Duncan, Homebuyer Master Class financing strategy speaker in Huntsville"
      />
      <div class="va-visual-card va-visual-card-top">
        <span>{site.tagline}</span>
        <strong>Homebuyer Master Class and buyer education events</strong>
      </div>
    </div>
  </section>

  <section class="section-band section-band-light" aria-labelledby="class-topics-heading">
    <div class="section-inner">
      <div class="section-heading section-heading-row">
        <div>
          <p class="eyebrow">What It Covers</p>
          <h2 id="class-topics-heading">A full view of the homebuying process.</h2>
        </div>
        <p>
          The Homebuyer Master Class is built to help buyers understand the
          major decisions before they are under contract. It gives first-time
          and experienced buyers a high-level framework without trying to turn
          the website into the full class.
        </p>
      </div>
      <div class="feature-grid feature-grid-five">
        {
          classTopics.map((topic) => (
            <article class="feature-card">
              <span>{topic.label}</span>
              <h3>{topic.title}</h3>
              <p>{topic.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-band" aria-labelledby="upcoming-heading">
    <div class="section-inner">
      <div class="section-heading section-heading-row">
        <div>
          <p class="eyebrow">Upcoming</p>
          <h2 id="upcoming-heading">Upcoming Homebuyer Master Class sessions.</h2>
        </div>
        <p>
          Upcoming sessions are listed here as they are scheduled. Each
          Homebuyer Master Class gives first-time and experienced buyers access
          to local subject matter experts before the pressure of an offer.
        </p>
      </div>
      <div class="event-grid">
        {
          upcomingEvents.length ? (
            upcomingEvents.map((event) => (
              <article class="event-card event-card-featured" id={event.id}>
                <p>{event.audience}</p>
                <h3>{event.name}</h3>
                <dl>
                  <div>
                    <dt>Date</dt>
                    <dd>
                      {formatEventDate(event.date)}
                      <a class="event-registration-link" href={getRegistrationUrl(event)}>
                        Register for this class
                      </a>
                    </dd>
                  </div>
                  <div>
                    <dt>Location</dt>
                    <dd>{eventAddress(event)}</dd>
                  </div>
                </dl>
                <p>{event.description}</p>
                <div class="expert-list expert-list-compact" aria-label={`${event.name} subject matter experts`}>
                  <p>Subject Matter Experts</p>
                  {event.speakers.map((speaker) => (
                    <div>
                      <strong>{speaker.topic}</strong>
                      <span>{speaker.name} · {speaker.company}</span>
                    </div>
                  ))}
                </div>
              </article>
            ))
          ) : (
            <article class="event-card">
              <p>Next date</p>
              <h3>Upcoming events will be posted here.</h3>
              <p>Past Homebuyer Master Class sessions remain visible as local credibility signals.</p>
            </article>
          )
        }
      </div>
    </div>
  </section>

  <section class="section-band section-band-light" aria-labelledby="past-heading">
    <div class="section-inner">
      <div class="section-heading section-heading-row">
        <div>
          <p class="eyebrow">Past Events</p>
          <h2 id="past-heading">Past Homebuyer Master Class sessions show local momentum.</h2>
        </div>
        <p>
          Past sessions stay visible because they show the local experts,
          locations, and buyer education themes already connected to Levi's
          work in Huntsville.
        </p>
      </div>
      <div class="event-stack">
        {
          pastEvents.map((event) => (
            <article class="event-card" id={event.id}>
              <p>{event.audience}</p>
              <h3>{event.name}</h3>
              <dl>
                <div>
                  <dt>Date</dt>
                  <dd>{formatEventDate(event.date)}</dd>
                </div>
                <div>
                  <dt>Location</dt>
                  <dd>{eventAddress(event)}</dd>
                </div>
              </dl>
              <p>{event.description}</p>
              <div class="expert-list expert-list-compact" aria-label={`${event.name} subject matter experts`}>
                <p>Subject Matter Experts</p>
                {event.speakers.map((speaker) => (
                  <div>
                    <strong>{speaker.topic}</strong>
                    <span>{speaker.name} · {speaker.company}</span>
                  </div>
                ))}
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
