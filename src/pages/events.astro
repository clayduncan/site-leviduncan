---
import BaseLayout from '../layouts/BaseLayout.astro';
import { events, pastEvents, upcomingEvents } from '../data/events';
import {
  createBreadcrumbJsonLd,
  createEventJsonLd,
  organizationJsonLd,
  personJsonLd,
} from '../data/schema';
import { site } from '../data/site';

const formatEventDate = (date: string) =>
  new Intl.DateTimeFormat('en', {
    month: 'long',
    day: 'numeric',
    year: 'numeric',
    hour: 'numeric',
    minute: '2-digit',
    timeZone: 'America/Chicago',
  }).format(new Date(date));

const schema = [
  personJsonLd,
  organizationJsonLd,
  ...events.map((event) => createEventJsonLd(event)),
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    '@id': `${site.url}/events/#webpage`,
    url: `${site.url}/events/`,
    name: 'Homebuyer Master Class',
    description:
      'Homebuyer Master Class events for Huntsville-area first-time and experienced homebuyers.',
    mainEntity: events.map((event) => ({ '@id': `${site.url}/events/#${event.id}` })),
    isPartOf: { '@id': `${site.url}/#website` },
  },
  createBreadcrumbJsonLd([
    { name: 'Home', path: '/' },
    { name: 'Events', path: '/events/' },
  ]),
];
---

<BaseLayout
  title="Homebuyer Master Class | Huntsville | Levi Duncan"
  description="View Levi Duncan's Homebuyer Master Class events for Huntsville-area first-time and experienced homebuyers."
  schema={schema}
>
  <section class="hero-section landing-hero va-landing-hero" aria-labelledby="events-heading">
    <div class="hero-copy">
      <p class="eyebrow">Events</p>
      <h1 id="events-heading">Homebuyer Master Class in Huntsville.</h1>
      <p class="hero-lede">
        Homebuyer Master Class is a monthly Huntsville-area education series for
        first-time and experienced buyers. Sessions bring together property
        strategy, title and legal, home inspection, homeowners insurance, and
        financing strategy so buyers can understand the full path before making
        a move.
      </p>
      <div class="hero-actions">
        <a class="button button-primary" href={site.calendlyUrl}>Book a call with Levi</a>
        <a class="button button-secondary" href={site.applicationUrl}>Apply with Levi</a>
      </div>
    </div>
    <div class="hero-media va-hero-media">
      <img
        src={site.heroImage}
        width="800"
        height="800"
        alt="Levi Duncan, Homebuyer Master Class financing strategy speaker in Huntsville"
      />
    </div>
  </section>

  <section class="section-band section-band-light" aria-labelledby="upcoming-heading">
    <div class="section-inner">
      <div class="section-heading">
        <p class="eyebrow">Upcoming</p>
        <h2 id="upcoming-heading">Upcoming Homebuyer Master Class events.</h2>
      </div>
      <div class="feature-grid">
        {
          upcomingEvents.length ? (
            upcomingEvents.map((event) => (
              <article class="feature-card" id={event.id}>
                <span>{formatEventDate(event.date)}</span>
                <h3>{event.name}</h3>
                <p>{event.venue}, {event.city}, {event.state}</p>
                <p>{event.description}</p>
                <div class="signal-list" aria-label={`${event.name} speakers`}>
                  {event.speakers.map((speaker) => (
                    <span>{speaker.name} - {speaker.company}: {speaker.topic}</span>
                  ))}
                </div>
              </article>
            ))
          ) : (
            <article class="feature-card">
              <span>Next date</span>
              <h3>Upcoming events will be posted here.</h3>
              <p>Past Homebuyer Master Class sessions remain visible as local credibility signals.</p>
            </article>
          )
        }
      </div>
    </div>
  </section>

  <section class="section-band section-band-light" aria-labelledby="past-heading">
    <div class="section-inner">
      <div class="section-heading">
        <p class="eyebrow">Past</p>
        <h2 id="past-heading">Past Homebuyer Master Class events in Huntsville.</h2>
      </div>
      <div class="feature-grid">
        {
          pastEvents.map((event) => (
            <article class="feature-card" id={event.id}>
              <span>{formatEventDate(event.date)}</span>
              <h3>{event.name}</h3>
              <p>{event.venue}, {event.city}, {event.state}</p>
              <p>{event.description}</p>
              <div class="signal-list" aria-label={`${event.name} speakers`}>
                {event.speakers.map((speaker) => (
                  <span>{speaker.name} - {speaker.company}: {speaker.topic}</span>
                ))}
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
